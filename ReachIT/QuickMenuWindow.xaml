<Window x:Class="ReachIT.QuickMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReachIT Quick Actions"
        Icon="Resources/AppIcon.ico"
        Width="320"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <Style x:Key="QuickActionButtonStyle"
               BasedOn="{StaticResource ReachItSecondaryButtonStyle}"
               TargetType="{x:Type Button}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource ReachItCardStyle}" Padding="12" CornerRadius="14">
        <StackPanel>
            <StackPanel Margin="4,2,4,10"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="TitleArea_MouseLeftButtonDown"
                        ToolTip="Drag to move quick actions.">
                <TextBlock Text="ReachIT Actions" Style="{StaticResource ReachItSectionTitleTextStyle}" Margin="0" />
                <TextBlock Text="Click or double-click the floating logo to open this menu."
                           Style="{StaticResource ReachItMutedTextStyle}"
                           FontSize="12" />
            </StackPanel>

            <Button Command="{Binding NewTaskCommand}"
                    ToolTip="Create a compact task without opening the main window. Hotkey: Ctrl+Alt+T">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="+ New Task" FontWeight="SemiBold" />
                        <TextBlock Text="Quickly capture a task." Style="{StaticResource ReachItMutedTextStyle}" FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="Ctrl+Alt+T" Style="{StaticResource ReachItMutedTextStyle}" VerticalAlignment="Center" />
                </Grid>
            </Button>

            <Button Command="{Binding ProjectExplorerCommand}"
                    Style="{StaticResource QuickActionButtonStyle}"
                    ToolTip="Open the lightweight project tree and file actions.">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="[ ] Project Explorer" FontWeight="SemiBold" />
                        <TextBlock Text="Files, folders, rename, delete, open." Style="{StaticResource ReachItMutedTextStyle}" FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="Panel" Style="{StaticResource ReachItMutedTextStyle}" VerticalAlignment="Center" />
                </Grid>
            </Button>

            <Button Command="{Binding FocusModeCommand}"
                    Style="{StaticResource QuickActionButtonStyle}"
                    ToolTip="Start or stop focus mode. Hotkey: Ctrl+Alt+F">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="( ) Focus Mode" FontWeight="SemiBold" />
                        <TextBlock Text="Toggle distraction tracking." Style="{StaticResource ReachItMutedTextStyle}" FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="Ctrl+Alt+F" Style="{StaticResource ReachItMutedTextStyle}" VerticalAlignment="Center" />
                </Grid>
            </Button>

            <Button Command="{Binding StatisticsCommand}" Style="{StaticResource QuickActionButtonStyle}" ToolTip="Open productivity statistics in the control center.">
                <StackPanel>
                    <TextBlock Text="# Statistics" FontWeight="SemiBold" />
                    <TextBlock Text="Focus time, task progress, productivity." Style="{StaticResource ReachItMutedTextStyle}" FontSize="12" />
                </StackPanel>
            </Button>

            <Button Command="{Binding MainWindowCommand}"
                    Style="{StaticResource QuickActionButtonStyle}"
                    ToolTip="Open the ReachIT control center. Hotkey: Ctrl+Alt+M">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="-> Main Window" FontWeight="SemiBold" />
                        <TextBlock Text="Open the control center." Style="{StaticResource ReachItMutedTextStyle}" FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="Ctrl+Alt+M" Style="{StaticResource ReachItMutedTextStyle}" VerticalAlignment="Center" />
                </Grid>
            </Button>

            <Button Command="{Binding SettingsCommand}" Style="{StaticResource QuickActionButtonStyle}" ToolTip="Open settings and preferences.">
                <StackPanel>
                    <TextBlock Text="* Settings" FontWeight="SemiBold" />
                    <TextBlock Text="Theme, hotkeys, startup behavior." Style="{StaticResource ReachItMutedTextStyle}" FontSize="12" />
                </StackPanel>
            </Button>

            <Button Command="{Binding HideCommand}"
                    Style="{StaticResource QuickActionButtonStyle}"
                    ToolTip="Hide the floating logo into the tray. Hotkey: Ctrl+Alt+R toggles it back.">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="- Hide" FontWeight="SemiBold" />
                        <TextBlock Text="Keep ReachIT running in tray." Style="{StaticResource ReachItMutedTextStyle}" FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="Ctrl+Alt+R" Style="{StaticResource ReachItMutedTextStyle}" VerticalAlignment="Center" />
                </Grid>
            </Button>

            <Button Command="{Binding ExitCommand}" Style="{StaticResource ReachItDangerButtonStyle}" ToolTip="Fully close ReachIT and remove tray/hotkeys.">
                <StackPanel>
                    <TextBlock Text="x Exit" FontWeight="SemiBold" />
                    <TextBlock Text="Completely close the app." Foreground="#FFE2EE" FontSize="12" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</Window>
