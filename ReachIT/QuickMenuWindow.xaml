<Window x:Class="ReachIT.QuickMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReachIT Quick Actions"
        Icon="Resources/AppIcon.ico"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Width="244"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="QuickTileStyle" BasedOn="{StaticResource ReachItSecondaryButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="66" />
            <Setter Property="Height" Value="58" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="MarkerButtonStyle" BasedOn="{StaticResource ReachItSecondaryButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource ReachItCardStyle}" Padding="10" CornerRadius="14">
        <StackPanel>
            <DockPanel Margin="2,0,2,8"
                       Cursor="SizeAll"
                       MouseLeftButtonDown="TitleArea_MouseLeftButtonDown"
                       ToolTip="Drag to move quick actions.">
                <TextBlock Text="ReachIT"
                           Foreground="{StaticResource SkyAquaBrush}"
                           FontSize="16"
                           FontWeight="Bold" />
                <TextBlock DockPanel.Dock="Right"
                           Text="Quick"
                           Style="{StaticResource ReachItMutedTextStyle}"
                           VerticalAlignment="Center" />
            </DockPanel>

            <Button Command="{Binding NewTaskCommand}"
                    Height="44"
                    Padding="10,4"
                    Margin="0,0,0,8"
                    ToolTip="Create a compact task without opening the main window. Hotkey: Ctrl+Alt+T">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="ClipboardPlus" Width="18" Height="18" Margin="0,0,8,0" />
                    <TextBlock Text="New Task" FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <UniformGrid Columns="3">
                <Button Command="{Binding ProjectExplorerCommand}" Style="{StaticResource QuickTileStyle}" ToolTip="Project explorer.">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="FileTree" Width="20" Height="20" HorizontalAlignment="Center" />
                        <TextBlock Text="Files" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding FocusModeCommand}" Style="{StaticResource QuickTileStyle}" ToolTip="Toggle focus mode.">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="ShieldCheck" Width="20" Height="20" HorizontalAlignment="Center" />
                        <TextBlock Text="Focus" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding WebResourcesCommand}" Style="{StaticResource QuickTileStyle}" ToolTip="Open Web Resources.">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="Web" Width="20" Height="20" HorizontalAlignment="Center" />
                        <TextBlock Text="Web" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding AddCurrentSiteCommand}" Style="{StaticResource QuickTileStyle}" ToolTip="Add URL from clipboard, or paste a URL.">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="LinkPlus" Width="20" Height="20" HorizontalAlignment="Center" />
                        <TextBlock Text="Site" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding StatisticsCommand}" Style="{StaticResource QuickTileStyle}" ToolTip="Statistics.">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="ChartTimelineVariant" Width="20" Height="20" HorizontalAlignment="Center" />
                        <TextBlock Text="Stats" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding MainWindowCommand}" Style="{StaticResource QuickTileStyle}" ToolTip="Main window.">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="20" Height="20" HorizontalAlignment="Center" />
                        <TextBlock Text="Main" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
            </UniformGrid>

            <TextBlock Text="Highlight copied text"
                       Style="{StaticResource ReachItMutedTextStyle}"
                       FontSize="11"
                       Margin="2,3,0,5" />
            <WrapPanel>
                <Button Command="{Binding HighlightCommand}" CommandParameter="yellow" Style="{StaticResource MarkerButtonStyle}" ToolTip="Save copied text as yellow highlight.">
                    <Border Width="26" Height="10" CornerRadius="5" Background="#FFD54A" />
                </Button>
                <Button Command="{Binding HighlightCommand}" CommandParameter="green" Style="{StaticResource MarkerButtonStyle}" ToolTip="Save copied text as green highlight.">
                    <Border Width="26" Height="10" CornerRadius="5" Background="#5BE48A" />
                </Button>
                <Button Command="{Binding HighlightCommand}" CommandParameter="pink" Style="{StaticResource MarkerButtonStyle}" ToolTip="Save copied text as pink highlight.">
                    <Border Width="26" Height="10" CornerRadius="5" Background="#EF2A97" />
                </Button>
                <Button Command="{Binding HighlightCommand}" CommandParameter="blue" Style="{StaticResource MarkerButtonStyle}" ToolTip="Save copied text as blue highlight.">
                    <Border Width="26" Height="10" CornerRadius="5" Background="#4DDCFF" />
                </Button>
            </WrapPanel>

            <WrapPanel>
                <Button Command="{Binding SettingsCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="Settings.">
                    <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18" />
                </Button>
                <Button Command="{Binding HideCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="Hide floating logo.">
                    <iconPacks:PackIconMaterial Kind="EyeOff" Width="18" Height="18" />
                </Button>
                <Button Command="{Binding ExitCommand}" Style="{StaticResource ReachItDangerIconButtonStyle}" ToolTip="Exit ReachIT.">
                    <iconPacks:PackIconMaterial Kind="Power" Width="18" Height="18" />
                </Button>
            </WrapPanel>
        </StackPanel>
    </Border>
</Window>
