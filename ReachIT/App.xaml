<Application x:Class="ReachIT.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ReachIT.Presentation.ViewModels"
             xmlns:views="clr-namespace:ReachIT.Presentation.Views">
    <Application.Resources>
        <DataTemplate DataType="{x:Type viewModels:MainDashboardViewModel}">
            <views:MainDashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ProjectInfoViewModel}">
            <views:ProjectInfoView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:FileViewModel}">
            <views:FileView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TaskManagerViewModel}">
            <views:TaskManagerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:StatisticsViewModel}">
            <views:StatisticsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PlanningViewModel}">
            <views:PlanningView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:VersionsViewModel}">
            <views:VersionsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:FocusModeViewModel}">
            <views:FocusModeView />
        </DataTemplate>
    </Application.Resources>
</Application>
