<Window x:Class="ReachIT.SidePanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ReachIT.Presentation.Views"
        Title="ReachIT Side Panel"
        Width="380"
        Height="760"
        WindowStyle="ToolWindow"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Window.InputBindings>
        <KeyBinding Key="R" Command="{Binding ToggleSidePanelCommand}" />
    </Window.InputBindings>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="61*" />
            <RowDefinition Height="7*"/>
            <RowDefinition Height="220" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Project Explorer" FontWeight="SemiBold" Margin="0,0,0,8" />

        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <Button Content="New File" Command="{Binding NewFileCommand}" Margin="0,0,6,6" />
            <Button Content="New Folder" Command="{Binding NewFolderCommand}" Margin="0,0,6,6" />
            <Button Content="Refresh" Command="{Binding RefreshTreeCommand}" Margin="0,0,6,6" />
            <Button Content="Open" Command="{Binding OpenSelectedNodeCommand}" Margin="0,0,6,6" />
            <Button Content="Reveal" Command="{Binding RevealSelectedNodeCommand}" Margin="0,0,6,6" />
            <Button Content="Rename" Command="{Binding RenameSelectedNodeCommand}" Margin="0,0,6,6" />
            <Button Content="Delete" Command="{Binding DeleteSelectedNodeCommand}" Margin="0,0,6,6" />
            <Button Content="Pin/Unpin Panel" Command="{Binding ToggleAppBarModeCommand}" Margin="0,0,6,6" />
            <Button Content="Open Main Window" Command="{Binding OpenMainWorkspaceCommand}" Margin="0,0,6,6" />
        </WrapPanel>

        <TreeView Grid.Row="2" ItemsSource="{Binding ProjectTreeViewModel.Nodes}" SelectedItemChanged="TreeView_SelectedItemChanged" MouseDoubleClick="TreeView_MouseDoubleClick" Grid.RowSpan="2">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}" />
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <Border Grid.Row="4" Margin="0,8,0,8" BorderThickness="1" BorderBrush="LightGray" Padding="6">
            <views:RecentExternalFilesPanel DataContext="{Binding RecentExternalFilesPanelViewModel}" />
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,220,0,0" Grid.RowSpan="2">
            <TextBlock Text="Focus:" FontWeight="SemiBold" Margin="0,0,4,0" />
            <TextBlock Text="{Binding FocusModeViewModel.IsActive, StringFormat='Active={0}'}" />
            <TextBlock Text=" | AppBar:" Margin="8,0,4,0" FontWeight="SemiBold" />
            <TextBlock Text="{Binding IsAppBarModeEnabled, StringFormat='Pinned={0}'}" />
        </StackPanel>
    </Grid>
</Window>
