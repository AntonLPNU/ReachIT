<Window x:Class="ReachIT.SidePanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="{DynamicResource Explorer.Title}"
        Icon="Resources/AppIcon.ico"
        Width="430"
        Height="860"
        MinWidth="320"
        MinHeight="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Grid Margin="8">
        <Border Padding="12"
                CornerRadius="20"
                Background="#E80D1626"
                BorderBrush="#55496B9A"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="26" ShadowDepth="0" Opacity="0.42" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Cursor="SizeAll"
                                MouseLeftButtonDown="TitleArea_MouseLeftButtonDown"
                                ToolTip="{DynamicResource Explorer.Title}">
                        <Image Source="Resources/AppIcon.png"
                               Width="22"
                               Height="22"
                               Margin="0,1,8,0" />
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Explorer.Title}" Style="{StaticResource ReachItSectionTitleTextStyle}" Margin="0" />
                            <TextBlock Text="Files, folders and linked tasks"
                                       Style="{StaticResource ReachItMutedTextStyle}"
                                       FontSize="11"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding ToggleAppBarModeCommand}"
                            Style="{StaticResource ReachItIconButtonStyle}"
                            Margin="0"
                            ToolTip="{DynamicResource Explorer.DockTip}">
                        <iconPacks:PackIconMaterial Kind="Pin" Width="18" Height="18" />
                    </Button>
                    <Button Grid.Column="2"
                            Click="CloseButton_Click"
                            Style="{StaticResource ReachItIconButtonStyle}"
                            Margin="6,0,0,0"
                            ToolTip="{DynamicResource Explorer.CloseTip}">
                        <iconPacks:PackIconMaterial Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>

                <Border Grid.Row="1"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="8"
                        Margin="0,0,0,10"
                        Background="#61101B2E"
                        BorderBrush="#263A5C">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusModeViewModel.IsActive}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="BorderBrush" Value="{StaticResource SkyAquaBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding NewFileCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.NewFileTip}">
                                <iconPacks:PackIconMaterial Kind="FilePlus" Width="18" Height="18" />
                            </Button>
                            <Button Command="{Binding NewFolderCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.NewFolderTip}">
                                <iconPacks:PackIconMaterial Kind="FolderPlus" Width="18" Height="18" />
                            </Button>
                            <Button Command="{Binding OpenTaskManagerCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.TaskTip}">
                                <iconPacks:PackIconMaterial Kind="ClipboardPlus" Width="18" Height="18" />
                            </Button>
                            <Button Command="{Binding AddWebResourceCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.AddWebResourceTip}">
                                <iconPacks:PackIconMaterial Kind="LinkPlus" Width="18" Height="18" />
                            </Button>
                            <Button Command="{Binding OpenWebResourcesCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="Open Web Resources">
                                <iconPacks:PackIconMaterial Kind="Web" Width="18" Height="18" />
                            </Button>
                            <Button Command="{Binding OpenSelectedNodeCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.OpenTip}">
                                <iconPacks:PackIconMaterial Kind="OpenInNew" Width="18" Height="18" />
                            </Button>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Command="{Binding RenameSelectedNodeCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.RenameTip}">
                                <iconPacks:PackIconMaterial Kind="Pencil" Width="18" Height="18" />
                            </Button>
                            <Button Command="{Binding DeleteSelectedNodeCommand}" Style="{StaticResource ReachItDangerIconButtonStyle}" ToolTip="{DynamicResource Explorer.DeleteTip}">
                                <iconPacks:PackIconMaterial Kind="Delete" Width="18" Height="18" />
                            </Button>
                            <Button Command="{Binding RefreshTreeCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.RefreshTip}">
                                <iconPacks:PackIconMaterial Kind="Refresh" Width="18" Height="18" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <TreeView Grid.Row="2"
                          x:Name="ProjectTree"
                          ItemsSource="{Binding ProjectTreeViewModel.Nodes}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          MouseDoubleClick="TreeView_MouseDoubleClick"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="Margin" Value="0" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="{Binding SelectedNodeIgnoreLabel}"
                                                  Command="{Binding ToggleSelectedNodeIgnoredCommand}" />
                                        <Separator />
                                        <MenuItem Header="{DynamicResource Explorer.OpenTip}"
                                                  Command="{Binding OpenSelectedNodeCommand}" />
                                        <MenuItem Header="{DynamicResource Explorer.RenameTip}"
                                                  Command="{Binding RenameSelectedNodeCommand}" />
                                        <MenuItem Header="{DynamicResource Explorer.DeleteTip}"
                                                  Command="{Binding DeleteSelectedNodeCommand}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Border CornerRadius="8"
                                    Padding="5,4"
                                    Margin="0"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="22"
                                            Height="22"
                                            CornerRadius="6"
                                            Background="{Binding IconBackground}"
                                            BorderBrush="#45FFFFFF"
                                            BorderThickness="1">
                                        <Grid>
                                            <iconPacks:PackIconMaterial Kind="Folder"
                                                                        Width="15"
                                                                        Height="15"
                                                                        Foreground="#7ED6FF"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                <iconPacks:PackIconMaterial.Style>
                                                    <Style TargetType="{x:Type iconPacks:PackIconMaterial}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowFolderIcon}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Kind" Value="FolderOpen" />
                                                                <Setter Property="Foreground" Value="#4DDCFF" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </iconPacks:PackIconMaterial.Style>
                                            </iconPacks:PackIconMaterial>
                                            <svgc:SvgViewbox Source="{Binding IconSource}"
                                                             Width="16"
                                                             Height="16"
                                                             Stretch="Uniform">
                                                <svgc:SvgViewbox.Style>
                                                    <Style TargetType="{x:Type svgc:SvgViewbox}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDownloadedIcon}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </svgc:SvgViewbox.Style>
                                            </svgc:SvgViewbox>
                                            <iconPacks:PackIconMaterial Kind="{Binding MaterialIconKind}"
                                                                        Width="15"
                                                                        Height="15"
                                                                        Foreground="{Binding IconForeground}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                <iconPacks:PackIconMaterial.Style>
                                                    <Style TargetType="{x:Type iconPacks:PackIconMaterial}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowMaterialIcon}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </iconPacks:PackIconMaterial.Style>
                                            </iconPacks:PackIconMaterial>
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding IconForeground}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowTextIcon}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding ExtensionBadge}"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding IconForeground}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowExtensionBadge}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding RelativePath}"
                                                   FontSize="9"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource ReachItMutedTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowSubtitle}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            MinWidth="24"
                                            Height="20"
                                            CornerRadius="10"
                                            Background="#22304A"
                                            BorderBrush="{StaticResource SkyAquaBrush}"
                                            BorderThickness="1"
                                            Margin="6,0,0,0">
                                        <TextBlock Text="{Binding AttachedTaskCount}"
                                                   Foreground="{StaticResource SkyAquaBrush}"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAttachedTasks}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <Button Grid.Column="3"
                                            Click="TaskBadge_Click"
                                            Margin="4,0,0,0"
                                            ToolTip="Show tasks linked to this file">
                                        <iconPacks:PackIconMaterial Kind="ClipboardTextOutline" Width="16" Height="16" />
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ReachItIconButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAttachedTasks}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>
    </Grid>
</Window>
