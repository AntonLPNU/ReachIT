<Window x:Class="ReachIT.SidePanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="{DynamicResource Explorer.Title}"
        Icon="Resources/AppIcon.ico"
        Width="360"
        Height="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Grid Margin="10">
        <Border Style="{StaticResource ReachItCardStyle}" Padding="12" CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Cursor="SizeAll"
                                MouseLeftButtonDown="TitleArea_MouseLeftButtonDown"
                                ToolTip="{DynamicResource Explorer.Title}">
                        <Image Source="Resources/AppIcon.png"
                               Width="18"
                               Height="18"
                               Margin="0,1,8,0" />
                        <TextBlock Text="{DynamicResource Explorer.Title}" Style="{StaticResource ReachItSectionTitleTextStyle}" Margin="0" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding ToggleAppBarModeCommand}"
                            Style="{StaticResource ReachItIconButtonStyle}"
                            Margin="0"
                            ToolTip="{DynamicResource Explorer.DockTip}">
                        <iconPacks:PackIconMaterial Kind="Pin" Width="18" Height="18" />
                    </Button>
                    <Button Grid.Column="2"
                            Click="CloseButton_Click"
                            Style="{StaticResource ReachItIconButtonStyle}"
                            Margin="6,0,0,0"
                            ToolTip="{DynamicResource Explorer.CloseTip}">
                        <iconPacks:PackIconMaterial Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>

                <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                    <Button Command="{Binding NewFileCommand}" Style="{StaticResource ReachItCompactButtonStyle}" ToolTip="{DynamicResource Explorer.NewFileTip}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FilePlus" Width="14" Height="14" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Explorer.NewFile}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NewFolderCommand}" Style="{StaticResource ReachItCompactButtonStyle}" ToolTip="{DynamicResource Explorer.NewFolderTip}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Explorer.NewFolder}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenTaskManagerCommand}" Style="{StaticResource ReachItCompactButtonStyle}" ToolTip="{DynamicResource Explorer.TaskTip}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ClipboardPlus" Width="14" Height="14" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Explorer.Task}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenSelectedNodeCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.OpenTip}">
                        <iconPacks:PackIconMaterial Kind="OpenInNew" Width="18" Height="18" />
                    </Button>
                    <Button Command="{Binding RenameSelectedNodeCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.RenameTip}">
                        <iconPacks:PackIconMaterial Kind="Pencil" Width="18" Height="18" />
                    </Button>
                    <Button Command="{Binding DeleteSelectedNodeCommand}" Style="{StaticResource ReachItDangerIconButtonStyle}" ToolTip="{DynamicResource Explorer.DeleteTip}">
                        <iconPacks:PackIconMaterial Kind="Delete" Width="18" Height="18" />
                    </Button>
                    <Button Command="{Binding RefreshTreeCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Explorer.RefreshTip}">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="18" Height="18" />
                    </Button>
                </WrapPanel>

                <TreeView Grid.Row="2"
                          ItemsSource="{Binding ProjectTreeViewModel.Nodes}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          MouseDoubleClick="TreeView_MouseDoubleClick"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" />
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>
    </Grid>
</Window>
