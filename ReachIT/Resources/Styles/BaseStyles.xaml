<!-- Shared visual language for ReachIT screens. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <!-- Palette supplied for ReachIT. -->
    <Color x:Key="NeonPinkColor">#F72585</Color>
    <Color x:Key="RaspberryPlumColor">#B5179E</Color>
    <Color x:Key="IndigoBloomColor">#7209B7</Color>
    <Color x:Key="UltrasonicBlueColor">#560BAD</Color>
    <Color x:Key="TrueAzureColor">#480CA8</Color>
    <Color x:Key="VividRoyalColor">#3A0CA3</Color>
    <Color x:Key="BrightIndigoColor">#3F37C9</Color>
    <Color x:Key="ElectricSapphireColor">#4361EE</Color>
    <Color x:Key="BlueEnergyColor">#4895EF</Color>
    <Color x:Key="SkyAquaColor">#4CC9F0</Color>

    <Color x:Key="ReachItInkColor">#EAF0FF</Color>
    <Color x:Key="ReachItMutedColor">#98A4BA</Color>
    <Color x:Key="ReachItSurfaceColor">#111827</Color>
    <Color x:Key="ReachItSoftSurfaceColor">#151E31</Color>
    <Color x:Key="ReachItBorderColor">#26324A</Color>
    <Color x:Key="ReachItInputColor">#0F1728</Color>

    <SolidColorBrush x:Key="NeonPinkBrush" Color="{StaticResource NeonPinkColor}" />
    <SolidColorBrush x:Key="RaspberryPlumBrush" Color="{StaticResource RaspberryPlumColor}" />
    <SolidColorBrush x:Key="IndigoBloomBrush" Color="{StaticResource IndigoBloomColor}" />
    <SolidColorBrush x:Key="UltrasonicBlueBrush" Color="{StaticResource UltrasonicBlueColor}" />
    <SolidColorBrush x:Key="TrueAzureBrush" Color="{StaticResource TrueAzureColor}" />
    <SolidColorBrush x:Key="VividRoyalBrush" Color="{StaticResource VividRoyalColor}" />
    <SolidColorBrush x:Key="BrightIndigoBrush" Color="{StaticResource BrightIndigoColor}" />
    <SolidColorBrush x:Key="ElectricSapphireBrush" Color="{StaticResource ElectricSapphireColor}" />
    <SolidColorBrush x:Key="BlueEnergyBrush" Color="{StaticResource BlueEnergyColor}" />
    <SolidColorBrush x:Key="SkyAquaBrush" Color="{StaticResource SkyAquaColor}" />
    <SolidColorBrush x:Key="ReachItInkBrush" Color="{StaticResource ReachItInkColor}" />
    <SolidColorBrush x:Key="ReachItMutedBrush" Color="{StaticResource ReachItMutedColor}" />
    <SolidColorBrush x:Key="ReachItSurfaceBrush" Color="{StaticResource ReachItSurfaceColor}" />
    <SolidColorBrush x:Key="ReachItSoftSurfaceBrush" Color="{StaticResource ReachItSoftSurfaceColor}" />
    <SolidColorBrush x:Key="ReachItBorderBrush" Color="{StaticResource ReachItBorderColor}" />
    <SolidColorBrush x:Key="ReachItInputBrush" Color="{StaticResource ReachItInputColor}" />

    <LinearGradientBrush x:Key="ReachItWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B0F1A" Offset="0" />
        <GradientStop Color="#0E1424" Offset="0.54" />
        <GradientStop Color="#101A2C" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ReachItHeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource NeonPinkColor}" Offset="0" />
        <GradientStop Color="{StaticResource IndigoBloomColor}" Offset="0.38" />
        <GradientStop Color="{StaticResource ElectricSapphireColor}" Offset="0.72" />
        <GradientStop Color="{StaticResource SkyAquaColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ReachItPrimaryBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource BrightIndigoColor}" Offset="0" />
        <GradientStop Color="{StaticResource ElectricSapphireColor}" Offset="0.6" />
        <GradientStop Color="{StaticResource BlueEnergyColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ReachItPrimaryHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource IndigoBloomColor}" Offset="0" />
        <GradientStop Color="{StaticResource ElectricSapphireColor}" Offset="0.55" />
        <GradientStop Color="{StaticResource SkyAquaColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ReachItDangerGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource NeonPinkColor}" Offset="0" />
        <GradientStop Color="{StaticResource RaspberryPlumColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ReachItTitleBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource NeonPinkColor}" Offset="0" />
        <GradientStop Color="{StaticResource TrueAzureColor}" Offset="0.52" />
        <GradientStop Color="{StaticResource BlueEnergyColor}" Offset="1" />
    </LinearGradientBrush>

    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{StaticResource ReachItWindowBackgroundBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style TargetType="{x:Type UserControl}">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="LineHeight" Value="19" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ReachItPageTitleTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource ReachItTitleBrush}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="34" />
    </Style>

    <Style x:Key="ReachItSectionTitleTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource SkyAquaBrush}" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="23" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="ReachItLabelTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#B8D7FF" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="ReachItMutedTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource ReachItMutedBrush}" />
    </Style>

    <Style TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource ReachItSurfaceBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ReachItCardStyle" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Background" Value="{StaticResource ReachItSoftSurfaceBrush}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="3"
                                  Direction="270"
                                  Opacity="0.28"
                                  Color="#05070D" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ReachItHeroCardStyle" BasedOn="{StaticResource ReachItCardStyle}" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource ReachItHeroBrush}" />
        <Setter Property="BorderBrush" Value="#80FFFFFF" />
    </Style>

    <Style x:Key="ReachItPanelStyle" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Background" Value="{StaticResource ReachItSoftSurfaceBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ReachItPanelHeaderStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#18243A" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="12,12,0,0" />
        <Setter Property="Padding" Value="18,14" />
    </Style>

    <Style x:Key="ReachItMetricCardStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#101827" />
        <Setter Property="BorderBrush" Value="#2B3E60" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ReachItWorkItemRowStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#121C2F" />
        <Setter Property="BorderBrush" Value="#233A5D" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,10,10" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                <Setter Property="Background" Value="#172640" />
                <Setter Property="BorderBrush" Value="#3A5F8A" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                <Setter Property="Background" Value="#1B304F" />
                <Setter Property="BorderBrush" Value="{StaticResource SkyAquaBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                <Setter Property="Opacity" Value="0.68" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type Button}">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="Margin" Value="0,0,6,6" />
        <Setter Property="Background" Value="{StaticResource ReachItPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="#4CC9F0" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ReachItPrimaryHoverBrush}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SkyAquaBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource TrueAzureBrush}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource BrightIndigoBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource NeonPinkBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Background" Value="#111827" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#33415E" />
                            <Setter Property="Foreground" Value="#9AA7BD" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ReachItSecondaryButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#18243A" />
        <Setter Property="BorderBrush" Value="#2D3C5C" />
        <Setter Property="Foreground" Value="{StaticResource SkyAquaBrush}" />
    </Style>

    <Style x:Key="ReachItDangerButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource ReachItDangerGradientBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="ReachItCompactButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,0,5,4" />
    </Style>

    <Style x:Key="ReachItActionButtonStyle" BasedOn="{StaticResource ReachItSecondaryButtonStyle}" TargetType="{x:Type Button}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="Margin" Value="0,0,0,7" />
    </Style>

    <Style x:Key="ReachItIconButtonStyle" BasedOn="{StaticResource ReachItSecondaryButtonStyle}" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="38" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,6,6" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="ReachItDangerIconButtonStyle" BasedOn="{StaticResource ReachItDangerButtonStyle}" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="38" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,6,6" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="ReachItTitleBarButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="34" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0"
                            CornerRadius="6"
                            Margin="2">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#25324A" />
                            <Setter Property="Foreground" Value="{StaticResource SkyAquaBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#31415F" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource ReachItInputBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource NeonPinkBrush}" />
        <Setter Property="SelectionBrush" Value="#804895EF" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ElectricSapphireBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Background" Value="#111827" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#33415E" />
                            <Setter Property="Foreground" Value="#9AA7BD" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="Background" Value="{StaticResource ReachItInputBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border x:Name="Chrome"
                                            Background="{StaticResource ReachItInputBrush}"
                                            BorderBrush="{StaticResource ReachItBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <ContentPresenter Margin="10,0,34,0"
                                                              HorizontalAlignment="Left"
                                                              VerticalAlignment="Center"
                                                              RecognizesAccessKey="True"
                                                              Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                            <TextBlock Text="v"
                                                       Foreground="{StaticResource SkyAquaBrush}"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource BlueEnergyBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border Background="{StaticResource ReachItSurfaceBrush}"
                                    BorderBrush="{StaticResource ReachItBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer Margin="4">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="Background" Value="{StaticResource ReachItSurfaceBrush}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="#1E293B" />
                <Setter Property="Foreground" Value="{StaticResource SkyAquaBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#203152" />
                <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
    </Style>

    <Style TargetType="{x:Type DatePicker}">
        <Setter Property="Background" Value="{StaticResource ReachItInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
    </Style>

    <Style TargetType="{x:Type primitives:DatePickerTextBox}">
        <Setter Property="Background" Value="{StaticResource ReachItInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="SelectionBrush" Value="#804895EF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:DatePickerTextBox}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,7" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Background" Value="#111827" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#33415E" />
                            <Setter Property="Foreground" Value="#9AA7BD" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{StaticResource TrueAzureBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="Background" Value="{StaticResource ReachItSoftSurfaceBrush}" />
    </Style>

    <Style TargetType="{x:Type ListBox}">
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="Background" Value="{StaticResource ReachItSoftSurfaceBrush}" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
    </Style>

    <Style TargetType="{x:Type TreeView}">
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="Background" Value="{StaticResource ReachItSoftSurfaceBrush}" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style TargetType="{x:Type TreeViewItem}">
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="Padding" Value="4,3" />
        <Setter Property="Margin" Value="0,1" />
    </Style>

    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{StaticResource ReachItSoftSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="#26324A" />
        <Setter Property="VerticalGridLinesBrush" Value="#26324A" />
        <Setter Property="RowHeight" Value="42" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="AlternatingRowBackground" Value="#121C2F" />
        <Setter Property="CanUserResizeRows" Value="False" />
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="#18243A" />
        <Setter Property="Foreground" Value="{StaticResource SkyAquaBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="{StaticResource ReachItSoftSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#18243A" />
                <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#203152" />
                <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="#111827" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="#111827" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="TopLevelChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <ContentPresenter x:Name="HeaderHost"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource ReachItSurfaceBrush}"
                                        BorderBrush="{StaticResource ReachItBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6"
                                        MinWidth="220">
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="SubmenuItem">
                            <Setter TargetName="TopLevelChrome" Property="CornerRadius" Value="6" />
                            <Setter TargetName="TopLevelChrome" Property="Padding" Value="14,8" />
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="TopLevelChrome" Property="CornerRadius" Value="6" />
                            <Setter TargetName="TopLevelChrome" Property="Padding" Value="14,8" />
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="TopLevelChrome" Property="Background" Value="#18243A" />
                            <Setter TargetName="TopLevelChrome" Property="BorderBrush" Value="{StaticResource BlueEnergyBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="TopLevelChrome" Property="Background" Value="#18243A" />
                            <Setter TargetName="TopLevelChrome" Property="BorderBrush" Value="{StaticResource SkyAquaBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#69758A" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type Separator}">
        <Setter Property="Margin" Value="6,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1" Background="#33415E" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{StaticResource ReachItSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="6">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background" Value="{StaticResource ReachItSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ReachItBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ToolBarTray}">
        <Setter Property="Background" Value="#101827" />
    </Style>

    <Style TargetType="{x:Type ToolBar}">
        <Setter Property="Background" Value="#101827" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style TargetType="{x:Type ProgressBar}">
        <Setter Property="Height" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource SkyAquaBrush}" />
        <Setter Property="Background" Value="#202A3F" />
    </Style>

    <Style x:Key="ReachItScrollLineButtonStyle" TargetType="{x:Type primitives:RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ReachItScrollThumbStyle" TargetType="{x:Type primitives:Thumb}">
        <Setter Property="MinWidth" Value="10" />
        <Setter Property="MinHeight" Value="96" />
        <Setter Property="Background" Value="#365B84" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                    <Border x:Name="ThumbChrome"
                            MinWidth="{TemplateBinding MinWidth}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#4CC9F0"
                            BorderThickness="1"
                            CornerRadius="5"
                            Margin="2" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="#4895EF" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="#4CC9F0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="16" />
        <Setter Property="Background" Value="#101B2E" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Width="{TemplateBinding Width}" Background="Transparent" SnapsToDevicePixels="True">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#223758"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="2,0" />
                        <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="2,3">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                              Style="{StaticResource ReachItScrollLineButtonStyle}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ReachItScrollThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                              Style="{StaticResource ReachItScrollLineButtonStyle}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="16" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid Height="{TemplateBinding Height}" Background="Transparent" SnapsToDevicePixels="True">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="#223758"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,2" />
                                <Track x:Name="PART_Track" Margin="3,2">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                                      Style="{StaticResource ReachItScrollLineButtonStyle}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb MinWidth="96" MinHeight="10" Style="{StaticResource ReachItScrollThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                                      Style="{StaticResource ReachItScrollLineButtonStyle}" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type ScrollViewer}">
        <Setter Property="Background" Value="Transparent" />
    </Style>
</ResourceDictionary>
