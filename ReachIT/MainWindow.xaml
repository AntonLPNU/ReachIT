<Window x:Class="ReachIT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource Main.Title}"
        Icon="Resources/AppIcon.ico"
        Height="700"
        Width="1200"
        MinHeight="520"
        MinWidth="900">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl+Shift" Key="R" Command="{Binding ToggleSidePanelCommand}" />
        <KeyBinding Modifiers="Alt" Key="Left" Command="{Binding GoBackCommand}" />
        <KeyBinding Modifiers="Alt" Key="Right" Command="{Binding GoForwardCommand}" />
    </Window.InputBindings>
    <Grid Background="{StaticResource ReachItWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="{DynamicResource Menu.File}">
                <MenuItem Header="{DynamicResource Menu.OpenProjectFolder}" Command="{Binding OpenProjectCommand}" />
                <Separator />
                <MenuItem Header="{DynamicResource Menu.Settings}" Command="{Binding OpenSettingsCommand}" />
                <MenuItem Header="{DynamicResource Menu.ExitApp}" Command="{Binding ExitApplicationCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.View}">
                <MenuItem Header="{DynamicResource Menu.ControlCenter}" Command="{Binding OpenMainViewCommand}" />
                <MenuItem Header="{DynamicResource Menu.Statistics}" Command="{Binding OpenStatisticsCommand}" />
                <MenuItem Header="{DynamicResource Menu.Settings}" Command="{Binding OpenSettingsCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Focus}">
                <MenuItem Header="{DynamicResource Menu.Start}" Command="{Binding StartFocusCommand}" />
                <MenuItem Header="{DynamicResource Menu.Stop}" Command="{Binding StopFocusCommand}" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Background="#101827" Padding="8,4" CornerRadius="0" BorderThickness="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding GoBackCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Main.BackTip}">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding GoForwardCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Main.ForwardTip}">
                        <iconPacks:PackIconMaterial Kind="ArrowRight" Width="20" Height="20" />
                    </Button>
                </StackPanel>

                <Border Grid.Column="1"
                        BorderBrush="{StaticResource ReachItBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10,4"
                        Margin="8,0,0,0"
                        Background="#151E31"
                        Visibility="{Binding FocusModeViewModel.IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Main.FocusLabel}" FontWeight="SemiBold" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding FocusModeViewModel.SessionDurationText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="16" Background="Transparent" BorderThickness="0">
            <ContentControl Content="{Binding CurrentWorkspaceViewModel}" />
        </Border>
    </Grid>
</Window>
