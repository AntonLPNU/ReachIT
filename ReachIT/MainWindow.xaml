<Window x:Class="ReachIT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource Main.Title}"
        Icon="Resources/AppIcon.ico"
        Height="700"
        Width="1200"
        MinHeight="520"
        MinWidth="900">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl+Shift" Key="R" Command="{Binding ToggleSidePanelCommand}" />
        <KeyBinding Modifiers="Alt" Key="Left" Command="{Binding GoBackCommand}" />
        <KeyBinding Modifiers="Alt" Key="Right" Command="{Binding GoForwardCommand}" />
    </Window.InputBindings>
    <Grid Background="{StaticResource ReachItWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="{DynamicResource Menu.File}">
                <MenuItem Header="{DynamicResource Menu.CreateProject}" Command="{Binding CreateProjectCommand}" />
                <MenuItem Header="{DynamicResource Menu.OpenProjectFolder}" Command="{Binding OpenProjectCommand}" />
                <MenuItem Header="{DynamicResource Menu.CloseProject}" Command="{Binding CloseProjectCommand}" />
                <Separator />
                <MenuItem Header="{DynamicResource Menu.AccountLogin}" Command="{Binding OpenAccountCommand}" />
                <MenuItem Header="{DynamicResource Menu.Settings}" Command="{Binding OpenSettingsCommand}" />
                <MenuItem Header="{DynamicResource Menu.ExitApp}" Command="{Binding ExitApplicationCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.View}">
                <MenuItem Header="{DynamicResource Menu.ControlCenter}" Command="{Binding OpenMainViewCommand}" />
                <MenuItem Header="{DynamicResource Menu.Activity}" Command="{Binding OpenActivityCommand}" />
                <MenuItem Header="{DynamicResource Menu.Statistics}" Command="{Binding OpenStatisticsCommand}" />
                <MenuItem Header="Web Resources" Command="{Binding OpenWebResourcesCommand}" />
                <MenuItem Header="Документація" Command="{Binding OpenDocumentationCommand}" />
                <MenuItem Header="{DynamicResource Menu.Settings}" Command="{Binding OpenSettingsCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Developer}"
                      Visibility="{Binding IsDeveloperToolsAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                <MenuItem Header="{DynamicResource Menu.TestPanel}" Command="{Binding OpenDeveloperTestPanelCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Focus}">
                <MenuItem Header="{DynamicResource Menu.Start}" Command="{Binding StartFocusCommand}" />
                <MenuItem Header="{DynamicResource Menu.Stop}" Command="{Binding StopFocusCommand}" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Background="#101827" Padding="8,4" CornerRadius="0" BorderThickness="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding GoBackCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Main.BackTip}">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding GoForwardCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Main.ForwardTip}">
                        <iconPacks:PackIconMaterial Kind="ArrowRight" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding OpenAccountCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Main.AccountLoginTip}">
                        <iconPacks:PackIconMaterial Kind="AccountCircle" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding CloseProjectCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="{DynamicResource Main.CloseProjectTip}">
                        <iconPacks:PackIconMaterial Kind="Home" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding OpenDeveloperTestPanelCommand}"
                            Style="{StaticResource ReachItIconButtonStyle}"
                            ToolTip="{DynamicResource Main.DeveloperTestPanelTip}"
                            Visibility="{Binding IsDeveloperToolsAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <iconPacks:PackIconMaterial Kind="Flask" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding OpenDocumentationCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="Документація ReachIT">
                        <iconPacks:PackIconMaterial Kind="HelpCircle" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding OpenWebResourcesCommand}" Style="{StaticResource ReachItIconButtonStyle}" ToolTip="Web Resources">
                        <iconPacks:PackIconMaterial Kind="Web" Width="20" Height="20" />
                    </Button>
                    <Border BorderBrush="{StaticResource ReachItBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,4"
                            Margin="6,0,0,6"
                            Background="#13243A"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountCheck" Width="15" Height="15" Foreground="{StaticResource SkyAquaBrush}" Margin="0,1,6,0" />
                            <TextBlock Text="{Binding AccountStatusText}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="2"
                        BorderBrush="{StaticResource SkyAquaBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10,4"
                        Margin="8,0,0,0"
                        Background="#13243A"
                        Visibility="{Binding FocusModeViewModel.IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ShieldCheck" Width="15" Height="15" Foreground="{StaticResource SkyAquaBrush}" Margin="0,1,6,0" />
                        <TextBlock Text="{DynamicResource Main.FocusLabel}" FontWeight="SemiBold" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding FocusModeViewModel.SessionDurationText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="16" Background="Transparent" BorderThickness="0">
            <ContentControl Content="{Binding CurrentWorkspaceViewModel}" />
        </Border>
    </Grid>
</Window>
