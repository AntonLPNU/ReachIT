<Window x:Class="ReachIT.AccountLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Account.WindowTitle}"
        Icon="Resources/AppIcon.ico"
        Width="460"
        Height="420"
        MinWidth="440"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
    <Border Background="{StaticResource ReachItWindowBackgroundBrush}"
            BorderBrush="{StaticResource ReachItBorderBrush}"
            BorderThickness="1"
            Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource Account.LoginTitle}"
                       Style="{StaticResource ReachItPageTitleTextStyle}"
                       FontSize="24"
                       Margin="0,0,0,14" />

            <TextBlock Text="{DynamicResource Account.Login}" Style="{StaticResource ReachItLabelTextStyle}" />
            <TextBox x:Name="LoginTextBox"
                     Text="developer"
                     Margin="0,4,0,12" />

            <TextBlock Text="{DynamicResource Account.Password}" Style="{StaticResource ReachItLabelTextStyle}" />
            <PasswordBox x:Name="PasswordBox"
                         Margin="0,4,0,12"
                         Padding="10,7"
                         Background="{StaticResource ReachItInputBrush}"
                         Foreground="{StaticResource ReachItInkBrush}"
                         BorderBrush="{StaticResource ReachItBorderBrush}"
                         KeyDown="OnPasswordKeyDown" />

            <Border Background="#101B2E"
                    BorderBrush="#253858"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Account.TestCredentials}"
                           Style="{StaticResource ReachItMutedTextStyle}" />
            </Border>

            <TextBlock x:Name="StatusText"
                       Text="{DynamicResource Account.LoginHelp}"
                       Style="{StaticResource ReachItMutedTextStyle}"
                       Margin="0,0,0,12" />
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button Click="OnSignInClick"
                        IsDefault="True"
                        Width="120">
                    <TextBlock Text="{DynamicResource Account.SignIn}" />
                </Button>
                <Button Click="OnUseDeveloperClick"
                        Width="170"
                        Style="{StaticResource ReachItSecondaryButtonStyle}">
                    <TextBlock Text="{DynamicResource Account.UseDeveloper}" />
                </Button>
                <Button Click="OnCancelClick"
                        Width="90"
                        Style="{StaticResource ReachItDangerButtonStyle}">
                    <TextBlock Text="{DynamicResource Account.Cancel}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
