<Window x:Class="ReachIT.CreateProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:ReachIT.Presentation.Views"
        Title="Create Project"
        Icon="Resources/AppIcon.ico"
        Height="500"
        Width="720"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource ReachItWindowBackgroundBrush}"
            BorderBrush="{StaticResource ReachItBorderBrush}"
            BorderThickness="1"
            CornerRadius="0">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Height="40"
                    Background="#151E31"
                    BorderBrush="{StaticResource ReachItBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="0"
                    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0">
                        <Image Source="Resources/AppIcon.png"
                               Width="20"
                               Height="20"
                               Margin="0,0,8,0" />
                        <TextBlock Text="Create Project"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ReachItInkBrush}" />
                    </StackPanel>

                    <Button Content="x"
                            HorizontalAlignment="Right"
                            Style="{StaticResource ReachItTitleBarButtonStyle}"
                            Foreground="{StaticResource NeonPinkBrush}"
                            ToolTip="Close"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OnCloseClick" />
                </Grid>
            </Border>

            <Grid Background="{StaticResource ReachItWindowBackgroundBrush}">
                <views:CreateProjectView />
            </Grid>
        </DockPanel>
    </Border>
</Window>
