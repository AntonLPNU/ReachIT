<Window x:Class="ReachIT.Presentation.Views.TaskDiagramStyleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export diagram"
        Width="430"
        Height="360"
        MinWidth="430"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        ResizeMode="CanMinimize">
    <Border Style="{StaticResource ReachItCardStyle}" Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Export diagram"
                       Style="{StaticResource ReachItSectionTitleTextStyle}" />

            <GroupBox Grid.Row="1"
                      Header="Style"
                      Margin="0,8,0,14"
                      Padding="12,10">
                <UniformGrid Columns="2">
                    <RadioButton x:Name="ReachItStyleOption"
                                 Content="ReachIT"
                                 IsChecked="True"
                                 Margin="0,0,12,0" />
                    <RadioButton x:Name="ClassicStyleOption"
                                 Content="Black and white" />
                </UniformGrid>
            </GroupBox>

            <GroupBox Grid.Row="2"
                      Header="Format"
                      Margin="0,0,0,18"
                      Padding="12,10">
                <StackPanel>
                    <RadioButton x:Name="PngOption"
                                 Content="PNG image"
                                 IsChecked="True"
                                 Margin="0,0,0,10" />
                    <RadioButton x:Name="SvgOption"
                                 Content="SVG vector"
                                 Margin="0,0,0,10" />
                    <RadioButton x:Name="DrawIoOption"
                                 Content="draw.io / diagrams.net" />
                </StackPanel>
            </GroupBox>

            <Button Content="Export"
                    Grid.Row="3"
                    HorizontalAlignment="Right"
                    MinWidth="110"
                    Click="Export_Click" />
        </Grid>
    </Border>
</Window>
