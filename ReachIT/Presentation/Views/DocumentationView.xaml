<!-- In-app user guide for ReachIT. -->
<UserControl x:Class="ReachIT.Presentation.Views.DocumentationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             TextElement.Foreground="{StaticResource ReachItInkBrush}">
    <UserControl.Resources>
        <Style x:Key="GuideCardStyle" BasedOn="{StaticResource ReachItCardStyle}" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="GuideSectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource SkyAquaBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="GuideSubTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#DDEBFF" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>

        <Style x:Key="GuideBodyStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="21" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="GuideMutedStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource ReachItMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="GuideStepStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource ReachItInkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="22" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="GuideTagStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#12243B" />
            <Setter Property="BorderBrush" Value="#2B5B86" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,18">
            <Border Style="{StaticResource ReachItCardStyle}" Padding="22" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="82"
                            Height="82"
                            CornerRadius="18"
                            Background="#101827"
                            BorderBrush="{StaticResource SkyAquaBrush}"
                            BorderThickness="1">
                        <Image Source="/ReachIT;component/Resources/AppIcon.png"
                               Width="62"
                               Height="62"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="Документація ReachIT"
                                   Style="{StaticResource ReachItPageTitleTextStyle}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="Практична інструкція з використання програми: що натискати, у якому порядку працювати і який результат очікувати."
                                   Style="{StaticResource GuideMutedStyle}"
                                   FontSize="14"
                                   MaxWidth="1040" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Style="{StaticResource GuideCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Зміст" Style="{StaticResource GuideSectionTitleStyle}" FontSize="18" />
                            <TextBlock Text="1. Швидкий старт" Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="2. Робота з задачами" Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="3. Прив’язка задач до файлів" Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="4. Діаграма і експорт" Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="5. Файли і безпечне превю" Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="6. Фокус-режим" Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="7. Статистика, Git і quick menu" Style="{StaticResource GuideStepStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GuideCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Корисна формула задачі" Style="{StaticResource GuideSectionTitleStyle}" FontSize="18" />
                            <TextBlock Text="Назва: дія + результат." Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Опис: як зрозуміти, що готово." Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Підзадачі: маленькі кроки без двозначності." Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Файл: де лежить реальна робота." Style="{StaticResource GuideStepStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource GuideCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconMaterial Kind="Home" Width="26" Height="26" Foreground="{StaticResource SkyAquaBrush}" Margin="0,0,10,0" />
                                <TextBlock Text="1. Швидкий старт" Style="{StaticResource GuideSectionTitleStyle}" />
                            </StackPanel>
                            <TextBlock Text="1. Відкрий стартовий екран і створи новий проєкт або вибери існуючу папку." Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="2. Вибери шаблон, якщо хочеш одразу отримати базові задачі. Для чистої роботи підійде порожній шаблон." Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="3. Після відкриття проєкту перевір dashboard: там видно шлях, прогрес, задачі на сьогодні, прострочені задачі, активність і Git-стан." Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="4. Далі працюй у трьох місцях: провідник файлів для матеріалів, менеджер задач для плану, фокус-режим для захисту від відволікань." Style="{StaticResource GuideStepStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GuideCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconMaterial Kind="FormatListChecks" Width="26" Height="26" Foreground="{StaticResource SkyAquaBrush}" Margin="0,0,10,0" />
                                <TextBlock Text="2. Робота з задачами" Style="{StaticResource GuideSectionTitleStyle}" />
                            </StackPanel>

                            <TextBlock Text="Створити задачу" Style="{StaticResource GuideSubTitleStyle}" />
                            <TextBlock Text="1. Відкрий «Менеджер задач». 2. Натисни «Додати задачу». 3. У полі «Назва» напиши конкретну дію: наприклад, «Додати превю для архівів», а не просто «Архіви». 4. У полі «Опис» напиши критерій готовності: «Показує список файлів архіву без розпакування і попереджає про підозрілі шляхи». 5. Натисни «Зберегти все»."
                                       Style="{StaticResource GuideStepStyle}" />

                            <TextBlock Text="Редагувати задачу" Style="{StaticResource GuideSubTitleStyle}" />
                            <TextBlock Text="1. Вибери задачу у списку або на діаграмі. 2. Зміни назву, опис, статус, дедлайн або позицію в черзі. 3. Перевір праву панель деталей. 4. Натисни «Зберегти все», щоб зміни записались у проєкт."
                                       Style="{StaticResource GuideStepStyle}" />

                            <TextBlock Text="Статуси" Style="{StaticResource GuideSubTitleStyle}" />
                            <WrapPanel Margin="0,4,0,6">
                                <Border Style="{StaticResource GuideTagStyle}">
                                    <TextBlock Text="Queued - чекає своєї черги" Style="{StaticResource GuideBodyStyle}" Margin="0" />
                                </Border>
                                <Border Style="{StaticResource GuideTagStyle}">
                                    <TextBlock Text="In Progress - робиш зараз" Style="{StaticResource GuideBodyStyle}" Margin="0" />
                                </Border>
                                <Border Style="{StaticResource GuideTagStyle}">
                                    <TextBlock Text="Done - результат готовий" Style="{StaticResource GuideBodyStyle}" Margin="0" />
                                </Border>
                            </WrapPanel>
                            <TextBlock Text="Не тримай багато задач у статусі In Progress. Краще мати 1-3 активні задачі, а решту залишити в Queued. Так dashboard і діаграма лишаються зрозумілими."
                                       Style="{StaticResource GuideStepStyle}" />

                            <TextBlock Text="Підзадачі" Style="{StaticResource GuideSubTitleStyle}" />
                            <TextBlock Text="Головна задача має бути етапом, а підзадачі - маленькими діями. Наприклад, головна задача «Зробити превю файлів», підзадачі: «Текст і код», «Зображення», «Архіви», «3D-моделі», «Перевірити FreeCAD-проєкт». Якщо задача стає довгою або нечіткою, розбий її на підзадачі."
                                       Style="{StaticResource GuideStepStyle}" />

                            <TextBlock Text="Черга і пріоритет" Style="{StaticResource GuideSubTitleStyle}" />
                            <TextBlock Text="Поле позиції в черзі допомагає впорядкувати роботу. Менше число означає, що задачу треба зробити раніше. Спочатку став у чергу блокери: без них інші задачі не мають сенсу."
                                       Style="{StaticResource GuideStepStyle}" />

                            <TextBlock Text="Видалення і завершення" Style="{StaticResource GuideSubTitleStyle}" />
                            <TextBlock Text="Щоб завершити задачу, вибери її і постав статус Done. Щоб прибрати зайве, виділи задачу й натисни «Видалити вибрану». Перед видаленням перевір, чи вона не є батьківською для потрібних підзадач."
                                       Style="{StaticResource GuideStepStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GuideCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconMaterial Kind="FileTree" Width="26" Height="26" Foreground="{StaticResource SkyAquaBrush}" Margin="0,0,10,0" />
                                <TextBlock Text="3. Прив’язка задач до файлів" Style="{StaticResource GuideSectionTitleStyle}" />
                            </StackPanel>
                            <TextBlock Text="1. Відкрий файл у дереві проєкту або на екрані превю. 2. Натисни «Attach Task». 3. Вибери існуючу задачу або створи нову під цей файл. 4. Після прив’язки задача буде показуватися поруч із файлом у деталях."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Коли це корисно: файл build.sh має задачу «Перевірити скрипт збірки», архів має задачу «Описати вміст без запуску», 3D-модель має задачу «Перевірити формат і розмір», зображення має задачу «Підготувати фінальний експорт»."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Правило безпеки: ReachIT може показати інформацію про файл, але не треба запускати невідомий файл тільки для перевірки. Для архівів користуйся безпечним списком вмісту."
                                       Style="{StaticResource GuideMutedStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GuideCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconMaterial Kind="Graph" Width="26" Height="26" Foreground="{StaticResource SkyAquaBrush}" Margin="0,0,10,0" />
                                <TextBlock Text="4. Діаграма задач і експорт" Style="{StaticResource GuideSectionTitleStyle}" />
                            </StackPanel>
                            <TextBlock Text="Діаграма показує задачі як дерево зверху вниз: проєкт, головні задачі, підзадачі. Це зручно для огляду всього плану, особливо коли список уже великий."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Керування: затисни мишку на фоні й рухай полотно; коліщатком змінюй масштаб; повернися до списку, якщо треба масово редагувати поля."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Експорт: натисни кнопку експорту, вибери стиль ReachIT або класичний чорно-білий, потім формат PNG, SVG або draw.io. PNG підходить для швидкої вставки у звіт. SVG краще для чіткої графіки. draw.io потрібен, якщо діаграму ще будуть редагувати вручну."
                                       Style="{StaticResource GuideStepStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GuideCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconMaterial Kind="FileDocument" Width="26" Height="26" Foreground="{StaticResource SkyAquaBrush}" Margin="0,0,10,0" />
                                <TextBlock Text="5. Файли і безпечне превю" Style="{StaticResource GuideSectionTitleStyle}" />
                            </StackPanel>
                            <TextBlock Text="Екран файлу віддає основний простір під вміст, а інструменти, задачі й метадані тримає збоку. Текст і код читаються напряму, зображення показуються як превю, аудіо/3D/бінарні формати отримують інформаційну картку."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Архіви перевіряються без запуску файлів усередині. ReachIT показує список елементів, розмір, типи та попередження про підозрілі шляхи. Це допомагає зрозуміти вміст, не відкриваючи потенційно небезпечні файли."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Кнопки: Open відкриває файл системною програмою; Reveal показує файл у провіднику; Attach Task прив’язує задачу; Snapshot зберігає стан/інформацію для подальшої роботи."
                                       Style="{StaticResource GuideStepStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GuideCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconMaterial Kind="ShieldCheck" Width="26" Height="26" Foreground="{StaticResource SkyAquaBrush}" Margin="0,0,10,0" />
                                <TextBlock Text="6. Фокус-режим" Style="{StaticResource GuideSectionTitleStyle}" />
                            </StackPanel>
                            <TextBlock Text="Фокус-режим перевіряє активне вікно. Дозволені робочі програми проходять без попередження. Браузер перевіряється точніше: робочі web-ресурси проєкту дозволяються, а короткі відео на YouTube Shorts, Instagram Reels, Facebook Watch і TikTok блокуються окремо."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Allow this app додає програму в whitelist. Використовуй це для справді робочих програм. Allow page once дозволяє тільки поточний URL браузера в цій focus-сесії. Наступний Shorts/Reels з іншим посиланням знову попросить підтвердження."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Для навчального YouTube-відео краще дозволити конкретну сторінку один раз, а не весь YouTube. Так корисний матеріал можна подивитися, але нескінченна стрічка не стає автоматично дозволеною."
                                       Style="{StaticResource GuideMutedStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GuideCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="26" Height="26" Foreground="{StaticResource SkyAquaBrush}" Margin="0,0,10,0" />
                                <TextBlock Text="7. Статистика, Git, quick menu і налаштування" Style="{StaticResource GuideSectionTitleStyle}" />
                            </StackPanel>
                            <TextBlock Text="Статистика показує виконані задачі, активність, фокус-сесії й продуктивність. Використовуй її наприкінці дня, щоб зрозуміти, що реально просунуло проєкт."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="Git-блок потрібен для базового контролю версій: перевір статус, додай зміни, зроби commit після завершення помітного етапу. Quick menu і плаваюче лого дають швидкий доступ до задач, фокусу, провідника, статистики й налаштувань без переходу через головне меню."
                                       Style="{StaticResource GuideStepStyle}" />
                            <TextBlock Text="У налаштуваннях тримай hotkeys, автозапуск, приватність назв вікон, whitelist фокусу та developer-режим. Якщо програма поводиться дивно, спершу перевір налаштування фокусу й дозволені програми."
                                       Style="{StaticResource GuideStepStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GuideCardStyle}" Background="#101827">
                        <StackPanel>
                            <TextBlock Text="Типовий робочий день у ReachIT" Style="{StaticResource GuideSectionTitleStyle}" />
                            <TextBlock Text="1. Відкрий dashboard і подивись активні задачі. 2. Вибери одну головну задачу й 1-3 підзадачі на зараз. 3. Прив’яжи потрібні файли. 4. Увімкни фокус. 5. Працюй по черзі, закриваючи Done тільки те, що має готовий результат. 6. Наприкінці збережи задачі, переглянь діаграму, зроби Git commit і за потреби експортуй дерево для звіту."
                                       Style="{StaticResource GuideStepStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
