<!-- Task manager workspace content. -->
<UserControl x:Class="ReachIT.Presentation.Views.TaskManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <UserControl.Resources>
        <HierarchicalDataTemplate x:Key="TaskTreeTemplate" ItemsSource="{Binding Subtasks}">
            <Grid MinHeight="54" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="128" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="96" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="FileTree"
                                                Width="18"
                                                Height="18"
                                                Margin="0,0,10,0"
                                                Foreground="{StaticResource SkyAquaBrush}" />
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Description}"
                                   Style="{StaticResource ReachItMutedTextStyle}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   MaxWidth="620" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Черга" Style="{StaticResource ReachItMutedTextStyle}" FontSize="11" />
                    <TextBlock Text="{Binding QueuePositionText}" Style="{StaticResource ReachItLabelTextStyle}" />
                </StackPanel>

                <Border Grid.Column="2"
                        Background="#18243A"
                        BorderBrush="#2D3C5C"
                        CornerRadius="7"
                        Padding="8,3"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource SkyAquaBrush}" FontWeight="SemiBold" />
                </Border>

                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DueDateUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                               Style="{StaticResource ReachItMutedTextStyle}" />
                    <TextBlock Text="{Binding CompletionAuditText}"
                               Style="{StaticResource ReachItMutedTextStyle}"
                               FontSize="11" />
                </StackPanel>

                <CheckBox Grid.Column="4"
                          IsChecked="{Binding IsCompleted, Mode=OneWay}"
                          Command="{Binding DataContext.MarkTaskCompletedCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                          CommandParameter="{Binding}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          ToolTip="Закрити задачу і зберегти час виконання.">
                    <CheckBox.Style>
                        <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Setter Property="Opacity" Value="0.9" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                    <CheckBox.LayoutTransform>
                        <ScaleTransform ScaleX="1.7" ScaleY="1.7" />
                    </CheckBox.LayoutTransform>
                </CheckBox>
            </Grid>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="640" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="0" Margin="0,0,14,0" CornerRadius="12" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#18243A" BorderThickness="0" CornerRadius="12,12,0,0" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="FileTree"
                                                        Width="26"
                                                        Height="26"
                                                        Margin="0,1,10,0"
                                                        Foreground="{StaticResource SkyAquaBrush}" />
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Tasks.ManagerTitle}" FontSize="22" FontWeight="Bold" />
                                <TextBlock Text="{DynamicResource Tasks.ManagerSubtitle}" Style="{StaticResource ReachItMutedTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="{DynamicResource Tasks.ActiveOnly}"
                                      IsChecked="{Binding ShowActiveOnly}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,14,0"
                                      ToolTip="{DynamicResource Tasks.ActiveOnlyTip}" />
                            <iconPacks:PackIconMaterial Kind="Magnify"
                                                        Width="18"
                                                        Height="18"
                                                        Margin="0,8,7,0"
                                                        Foreground="{StaticResource SkyAquaBrush}" />
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="230"
                                     ToolTip="Filter tasks by title or description." />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <TextBlock Text="{DynamicResource Tasks.Empty}"
                               Visibility="{Binding EmptyStateVisibility}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Style="{StaticResource ReachItMutedTextStyle}"
                               FontSize="16" />

                    <TreeView x:Name="TaskTree"
                              ItemsSource="{Binding TreeTasks}"
                              ItemTemplate="{StaticResource TaskTreeTemplate}"
                              SelectedItemChanged="TaskTree_SelectedItemChanged"
                              BorderThickness="0"
                              Padding="14"
                              Background="{StaticResource ReachItSoftSurfaceBrush}">
                        <TreeView.Resources>
                            <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="True" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                            </Style>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource ReachItCardStyle}" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="#101827" BorderBrush="#33415E" CornerRadius="8" Padding="10,8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Tasks.Total}" Style="{StaticResource ReachItMutedTextStyle}" FontSize="11" />
                                <TextBlock Text="{Binding Tasks.Count}" FontSize="20" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Background="#101827" BorderBrush="#33415E" CornerRadius="8" Padding="10,8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Tasks.DueTodayCount}" Style="{StaticResource ReachItMutedTextStyle}" FontSize="11" />
                                <TextBlock Text="{Binding DueTodayCount}" FontSize="20" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Background="#101827" BorderBrush="#33415E" CornerRadius="8" Padding="10,8">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Tasks.OverdueCount}" Style="{StaticResource ReachItMutedTextStyle}" FontSize="11" />
                                <TextBlock Text="{Binding OverdueTasksCount}" FontSize="20" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <WrapPanel Margin="0,0,0,10">
                        <Button Command="{Binding AddTaskCommand}" ToolTip="Create a new task.">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="PlusCircle" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Tasks.Add}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SaveAllCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" ToolTip="Save every task marked as unsaved.">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Tasks.SaveAll}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DeleteTaskCommand}" Style="{StaticResource ReachItDangerButtonStyle}" ToolTip="Delete the selected task.">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Delete" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Tasks.DeleteSelected}" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <Separator Margin="0,0,0,12" />

                    <StackPanel IsEnabled="{Binding IsTaskSelected}"
                                ToolTip="{DynamicResource Tasks.SelectTip}"
                                ToolTipService.ShowOnDisabled="True">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <iconPacks:PackIconMaterial Kind="ClipboardText" Width="22" Height="22" Margin="0,1,9,0" Foreground="{StaticResource SkyAquaBrush}" />
                            <TextBlock Text="{DynamicResource Tasks.Details}" Style="{StaticResource ReachItSectionTitleTextStyle}" Margin="0" />
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Tasks.Title}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" ToolTip="Task title." />

                        <TextBlock Text="{DynamicResource Tasks.Description}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 MinHeight="96"
                                 TextWrapping="Wrap"
                                 Margin="0,2,0,10"
                                 ToolTip="Notes or details for this task." />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Позиція в черзі" Style="{StaticResource ReachItLabelTextStyle}" />
                                <TextBox Text="{Binding EditPriority, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0" ToolTip="Lower queue numbers are handled first."/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource Tasks.Status}" Style="{StaticResource ReachItLabelTextStyle}" />
                                <TextBox Text="{Binding EditStatus, Mode=OneWay}" IsReadOnly="True" Margin="0,2,0,0" ToolTip="Status is tracked automatically from the task queue."/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{DynamicResource Tasks.Deadline}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <DatePicker SelectedDate="{Binding EditDeadlineDate}" Margin="0,2,0,8" ToolTip="Pick the task deadline." />
                        <CheckBox Content="{DynamicResource Tasks.Completed}" IsChecked="{Binding EditIsCompleted}" Margin="0,0,0,10" ToolTip="Mark this task as completed." />

                        <WrapPanel Margin="0,0,0,10">
                            <Button Content="{DynamicResource Tasks.Today}" Command="{Binding SetDeadlineTodayCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" ToolTip="Set deadline to today." />
                            <Button Content="{DynamicResource Tasks.Tomorrow}" Command="{Binding SetDeadlineTomorrowCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" ToolTip="Set deadline to tomorrow." />
                            <Button Content="{DynamicResource Tasks.Clear}" Command="{Binding ClearDeadlineCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" ToolTip="Remove the deadline." />
                        </WrapPanel>

                        <Button Command="{Binding EditTaskCommand}" ToolTip="Apply edits to the selected task. Use Save All to write unsaved tasks.">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Tasks.Apply}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding AddSubtaskCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" ToolTip="Create a child task under the selected task.">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="FileTree" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Tasks.AddSubtask}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding MarkCompletedCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" ToolTip="Mark the selected task as completed.">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="Check" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Tasks.MarkCompleted}" />
                            </StackPanel>
                        </Button>

                        <TextBlock Text="{Binding DeadlineValidationMessage}" Foreground="{StaticResource NeonPinkBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
