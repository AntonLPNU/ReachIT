<!-- File preview workspace with side tools and safe metadata inspection. -->
<UserControl x:Class="ReachIT.Presentation.Views.FileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="620" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding FileName}"
                               Style="{StaticResource ReachItPageTitleTextStyle}"
                               FontSize="24"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding RelativePath}"
                               Style="{StaticResource ReachItMutedTextStyle}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource ReachItMetricCardStyle}"
                        VerticalAlignment="Center"
                        Padding="12,7">
                    <TextBlock Text="{Binding ReadCapability}"
                               Foreground="{StaticResource SkyAquaBrush}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Style="{StaticResource ReachItPanelStyle}"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource ReachItPanelHeaderStyle}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FileEye"
                                                        Width="23"
                                                        Height="23"
                                                        Margin="0,0,10,0"
                                                        Foreground="{StaticResource SkyAquaBrush}" />
                            <TextBlock Text="Preview"
                                       Style="{StaticResource ReachItSectionTitleTextStyle}"
                                       Margin="0" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Background="#101827">
                        <TextBlock Text="No inline preview is available for this file type. Use the side panel to inspect metadata or open the file externally."
                                   Style="{StaticResource ReachItMutedTextStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   MaxWidth="520"
                                   Margin="28" />

                        <TextBox Text="{Binding TextPreview}"
                                 Visibility="{Binding CanPreviewAsText, Converter={StaticResource BoolToVisibilityConverter}}"
                                 IsReadOnly="True"
                                 FontFamily="Cascadia Mono, Consolas"
                                 FontSize="13"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 Background="#0B1220"
                                 BorderThickness="0"
                                 Padding="18" />

                        <TextBox Text="{Binding TextPreview}"
                                 Visibility="{Binding CanPreviewAsArchive, Converter={StaticResource BoolToVisibilityConverter}}"
                                 IsReadOnly="True"
                                 FontFamily="Cascadia Mono, Consolas"
                                 FontSize="13"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 Background="#0B1220"
                                 BorderThickness="0"
                                 Padding="18" />

                        <TextBox Text="{Binding TextPreview}"
                                 Visibility="{Binding CanPreviewAsModel, Converter={StaticResource BoolToVisibilityConverter}}"
                                 IsReadOnly="True"
                                 FontFamily="Cascadia Mono, Consolas"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#0B1220"
                                 BorderThickness="0"
                                 Padding="18" />

                        <ScrollViewer Visibility="{Binding CanPreviewAsImage, Converter={StaticResource BoolToVisibilityConverter}}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Background="#0B1220">
                            <Image Source="{Binding ImagePath}"
                                   Stretch="Uniform"
                                   Margin="18" />
                        </ScrollViewer>

                        <Grid Visibility="{Binding CanPreviewAsAudio, Converter={StaticResource BoolToVisibilityConverter}}"
                              Background="#0B1220">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="420">
                                <iconPacks:PackIconMaterial Kind="Waveform"
                                                            Width="54"
                                                            Height="54"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{StaticResource SkyAquaBrush}"
                                                            Margin="0,0,0,14" />
                                <TextBlock Text="{Binding FileName}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Audio file recognized. Use Open for playback in your trusted media app."
                                           Style="{StaticResource ReachItMutedTextStyle}"
                                           TextAlignment="Center"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2"
                Style="{StaticResource ReachItCardStyle}"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Tools"
                               Style="{StaticResource ReachItSectionTitleTextStyle}" />
                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <Button Content="Open"
                                Command="{Binding OpenFileCommand}"
                                Visibility="{Binding IsRegularFile, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Open URL"
                                Command="{Binding OpenWebResourceCommand}"
                                Visibility="{Binding IsWebResource, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Reveal"
                                Command="{Binding RevealInExplorerCommand}"
                                Style="{StaticResource ReachItSecondaryButtonStyle}" />
                        <Button Content="Snapshot"
                                Command="{Binding CreateSnapshotCommand}"
                                Style="{StaticResource ReachItSecondaryButtonStyle}" />
                    </UniformGrid>
                    <Button Command="{Binding AttachTaskCommand}"
                            Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="PlusCircle"
                                                        Width="16"
                                                        Height="16"
                                                        Margin="0,0,8,0" />
                            <TextBlock Text="Attach task" />
                        </StackPanel>
                    </Button>

                    <Separator Margin="0,4,0,14" />

                    <TextBlock Text="Tasks"
                               Style="{StaticResource ReachItSectionTitleTextStyle}" />
                    <TextBlock Text="{Binding AttachedTasksSummary}"
                               Style="{StaticResource ReachItMutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding AttachedTasks}" Margin="0,0,0,14">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ReachItMetricCardStyle}"
                                        Margin="0,0,0,7">
                                    <TextBlock Text="{Binding Title}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,4,0,14" />

                    <TextBlock Text="File metadata"
                               Style="{StaticResource ReachItSectionTitleTextStyle}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Kind" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding FileKind}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1" Text="Extension" Style="{StaticResource ReachItLabelTextStyle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Extension}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="2" Text="Size" Style="{StaticResource ReachItLabelTextStyle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FileSizeText}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="3" Text="Created" Style="{StaticResource ReachItLabelTextStyle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CreatedAtText}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="4" Text="Modified" Style="{StaticResource ReachItLabelTextStyle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastModifiedText}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="5" Text="Exists" Style="{StaticResource ReachItLabelTextStyle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Exists}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="6" Text="Path" Style="{StaticResource ReachItLabelTextStyle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding FullPath}" Margin="0,8,0,0" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="7" Text="Relative" Style="{StaticResource ReachItLabelTextStyle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding RelativePath}" Margin="0,8,0,0" TextWrapping="Wrap" />
                    </Grid>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource NeonPinkBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14" />

                    <Border Style="{StaticResource ReachItMetricCardStyle}"
                            Visibility="{Binding IsWebResource, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Web metadata"
                                       Style="{StaticResource ReachItSectionTitleTextStyle}" />
                            <TextBlock Text="Title" Style="{StaticResource ReachItLabelTextStyle}" />
                            <TextBox Text="{Binding WebTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8" />
                            <TextBlock Text="Primary URL" Style="{StaticResource ReachItLabelTextStyle}" />
                            <TextBox Text="{Binding WebPrimaryUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8" />
                            <TextBlock Text="Focus hosts" Style="{StaticResource ReachItLabelTextStyle}" />
                            <TextBox Text="{Binding WebAllowedFocusHostsText, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="70"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,3,0,8" />
                            <TextBlock Text="Notes" Style="{StaticResource ReachItLabelTextStyle}" />
                            <TextBox Text="{Binding WebNotes, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,3,0,8" />
                            <Button Content="Save Web Metadata"
                                    Command="{Binding SaveWebResourceCommand}"
                                    Style="{StaticResource ReachItSecondaryButtonStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
