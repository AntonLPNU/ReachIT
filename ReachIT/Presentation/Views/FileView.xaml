<!-- File workspace metadata and preview content. -->
<UserControl x:Class="ReachIT.Presentation.Views.FileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding FileName}" FontSize="20" FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Margin="0,8,0,0">
            <TextBlock Text="{Binding RelativePath, StringFormat=Relative: {0}}" />
            <TextBlock Text="{Binding FullPath, StringFormat=Path: {0}}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Extension, StringFormat=Extension: {0}}" />
            <TextBlock Text="{Binding FileSizeText, StringFormat=Size: {0}}" />
            <TextBlock Text="{Binding CreatedAtText, StringFormat=Created: {0}}" />
            <TextBlock Text="{Binding LastModifiedText, StringFormat=Modified: {0}}" />
            <TextBlock Text="{Binding Exists, StringFormat=Exists: {0}}" />
            <TextBlock Text="{Binding AttachedTasksSummary, StringFormat=Attached tasks: {0}}" TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding AttachedTasks}" Margin="0,4,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="DarkRed" TextWrapping="Wrap" />
        </StackPanel>

        <WrapPanel Grid.Row="2" Margin="0,8,0,8">
            <Button Content="Open" Command="{Binding OpenFileCommand}" Margin="0,0,6,6" />
            <Button Content="Reveal" Command="{Binding RevealInExplorerCommand}" Margin="0,0,6,6" />
            <Button Content="Attach Task" Command="{Binding AttachTaskCommand}" Margin="0,0,6,6" />
            <Button Content="Snapshot" Command="{Binding CreateSnapshotCommand}" Margin="0,0,6,6" />
        </WrapPanel>

        <Grid Grid.Row="3">
            <TextBox Text="{Binding TextPreview}"
                     Visibility="{Binding CanPreviewAsText, Converter={StaticResource BoolToVisibilityConverter}}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AcceptsReturn="True" />

            <ScrollViewer Visibility="{Binding CanPreviewAsImage, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <Image Source="{Binding ImagePath}" Stretch="Uniform" />
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
