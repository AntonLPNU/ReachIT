<!-- Focus mode placeholder content. -->
<UserControl x:Class="ReachIT.Presentation.Views.FocusModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:ReachIT.Domain.Enums">
    <Grid>
        <StackPanel>
            <TextBlock Text="Focus Mode" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
            <ComboBox SelectedItem="{Binding SelectedMode}" Margin="0,0,0,8">
                <ComboBox.ItemsSource>
                    <x:Array Type="{x:Type enums:FocusModeType}">
                        <enums:FocusModeType>Light</enums:FocusModeType>
                        <enums:FocusModeType>Strict</enums:FocusModeType>
                        <enums:FocusModeType>Aggressive</enums:FocusModeType>
                    </x:Array>
                </ComboBox.ItemsSource>
            </ComboBox>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Start" Command="{Binding StartCommand}" Margin="0,0,8,0" />
                <Button Content="Stop" Command="{Binding StopCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding IsActive, StringFormat=Active: {0}}" />
            <TextBlock Margin="0,8,0,0" Text="Allowed Applications:" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding AllowedApplications}" />
        </StackPanel>
    </Grid>
</UserControl>
