<UserControl x:Class="ReachIT.Presentation.Views.FocusModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Focus Mode" Style="{StaticResource ReachItPageTitleTextStyle}" FontSize="24" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding StartCommand}" ToolTip="Start strict focus mode.">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Play" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="Start" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding PauseCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" ToolTip="Pause focus checks.">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Pause" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="Pause" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding StopCommand}" Style="{StaticResource ReachItDangerButtonStyle}" ToolTip="Stop focus mode.">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Stop" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="Stop" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Margin="0,0,0,12" Padding="14" CornerRadius="10" Background="#151E31" BorderBrush="#253858" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="12" Height="12" CornerRadius="6" BorderThickness="0" Margin="0,0,10,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#516078" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SkyAquaBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding FocusStatusText}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBlock Text="Choose which installed apps are allowed while focus is active."
                                   Style="{StaticResource ReachItMutedTextStyle}" />
                    </StackPanel>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding SessionDurationText}"
                           Foreground="{StaticResource ReachItTitleBrush}"
                           FontSize="28"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ReachItCardStyle}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Installed Apps" Style="{StaticResource ReachItSectionTitleTextStyle}" Margin="0,0,0,2" />
                            <TextBlock Text="Real apps from Start Menu and Program Files. Runtimes and SDK components are hidden."
                                       Style="{StaticResource ReachItMutedTextStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding RefreshInstalledApplicationsCommand}"
                                Style="{StaticResource ReachItIconButtonStyle}"
                                ToolTip="Refresh installed app list.">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="18" Height="18" />
                        </Button>
                    </Grid>

                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding ApplicationSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"
                             ToolTip="Search by app name, publisher, or process name." />

                    <DataGrid ItemsSource="{Binding FilteredInstalledApplications}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              RowHeight="34"
                              GridLinesVisibility="Vertical"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Name" Width="2.3*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="22" Height="22" Margin="0,0,7,0">
                                                <iconPacks:PackIconMaterial Kind="ApplicationCog" Width="17" Height="17" Foreground="{StaticResource SkyAquaBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Image Source="{Binding IconSource}" Width="20" Height="20" />
                                            </Grid>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="1.35*" />
                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="1*" />
                            <DataGridTextColumn Header="Source" Binding="{Binding SourceLabel}" Width="0.75*" />
                            <DataGridTemplateColumn Header="" Width="86">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Right">
                                            <Button Command="{Binding DataContext.AddInstalledApplicationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    MinHeight="24"
                                                    Padding="8,2"
                                                    Margin="0"
                                                    Visibility="{Binding IsNotAllowed, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    ToolTip="Allow this app during focus.">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="Plus" Width="13" Height="13" Margin="0,0,4,0" />
                                                    <TextBlock Text="Allow" FontSize="12" />
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding DataContext.RemoveInstalledApplicationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource ReachItSecondaryButtonStyle}"
                                                    MinHeight="24"
                                                    Padding="8,2"
                                                    Margin="0"
                                                    Visibility="{Binding IsAllowed, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    ToolTip="Remove this app from focus whitelist.">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="Check" Width="13" Height="13" Margin="0,0,4,0" />
                                                    <TextBlock Text="OK" FontSize="12" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ReachItCardStyle}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Focus Whitelist" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <Button DockPanel.Dock="Right"
                                Command="{Binding AddActiveAppCommand}"
                                Style="{StaticResource ReachItSecondaryButtonStyle}"
                                ToolTip="Add the currently active Windows app to the whitelist.">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Plus" Width="15" Height="15" Margin="0,0,6,0" />
                                <TextBlock Text="Current" />
                            </StackPanel>
                        </Button>
                    </DockPanel>

                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ManualApplicationName, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Type a process name manually." />
                        <Button Grid.Column="1"
                                Command="{Binding AddManualApplicationCommand}"
                                Margin="8,0,0,0"
                                Style="{StaticResource ReachItSecondaryButtonStyle}"
                                ToolTip="Add this process name.">
                            <iconPacks:PackIconMaterial Kind="Check" Width="16" Height="16" />
                        </Button>
                    </Grid>

                    <Button DockPanel.Dock="Bottom"
                            Command="{Binding SaveFocusRulesCommand}"
                            Margin="0,10,0,0"
                            ToolTip="Save current whitelist.">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" Margin="0,0,8,0" />
                            <TextBlock Text="Save whitelist" />
                        </StackPanel>
                    </Button>

                    <DataGrid ItemsSource="{Binding AllowedApplicationRules}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              RowHeight="34"
                              GridLinesVisibility="Vertical"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="34">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Allow this app during Focus Mode." />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Name" Width="1.7*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="22" Height="22" Margin="0,0,7,0">
                                                <iconPacks:PackIconMaterial Kind="ApplicationCog" Width="17" Height="17" Foreground="{StaticResource SkyAquaBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Image Source="{Binding IconSource}" Width="20" Height="20" />
                                            </Grid>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="1*" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="" Width="42">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.RemoveApplicationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ReachItIconButtonStyle}"
                                                Width="26"
                                                Height="24"
                                                Margin="0"
                                                ToolTip="Remove from whitelist.">
                                            <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
