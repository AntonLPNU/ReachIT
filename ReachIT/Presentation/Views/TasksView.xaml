<!-- Task Manager placeholder content. -->
<UserControl x:Class="ReachIT.Presentation.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Task Manager" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
        <ListBox Grid.Row="1" ItemsSource="{Binding Tasks}" DisplayMemberPath="Title" />
    </Grid>
</UserControl>
