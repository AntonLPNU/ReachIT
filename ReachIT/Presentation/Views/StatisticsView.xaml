<!-- Statistics placeholder content. -->
<UserControl x:Class="ReachIT.Presentation.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <StackPanel>
                <TextBlock Text="{DynamicResource Stats.Title}" Style="{StaticResource ReachItPageTitleTextStyle}" Margin="0,0,0,16" />

                <WrapPanel>
                    <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,16,16" MinWidth="200">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Stats.TaskOverview}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource Stats.TotalTasks}" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding ProjectStats.TotalTasks}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource Dashboard.Completed}" Margin="0,0,4,0" Foreground="{StaticResource BlueEnergyBrush}" />
                                <TextBlock Text="{Binding ProjectStats.CompletedTasks}" Foreground="{StaticResource BlueEnergyBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource Stats.CompletionRate}" Margin="0,0,4,0" Style="{StaticResource ReachItLabelTextStyle}" />
                                <TextBlock Text="{Binding CompletionRate, StringFormat={}{0:F1}%}" Style="{StaticResource ReachItLabelTextStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,16,16" MinWidth="200">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Stats.FocusTime}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource Stats.TotalTime}" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding ProjectStats.FocusHours, StringFormat={}{0:F1} hrs}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,16,16" MinWidth="200">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Stats.ProjectContext}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource Stats.TotalFiles}" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding ProjectStats.TotalFiles}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats.Trends}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <DataGrid ItemsSource="{Binding Productivity}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Stats.Date}" Binding="{Binding DateUtc, StringFormat='{}{0:yyyy-MM-dd}'}" Width="150" />
                                <DataGridTextColumn Header="{DynamicResource Stats.CompletedTasks}" Binding="{Binding CompletedTasks}" Width="170" />
                                <DataGridTextColumn Header="{DynamicResource Stats.FocusHours}" Binding="{Binding FocusHours, StringFormat='{}{0:F1}'}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
