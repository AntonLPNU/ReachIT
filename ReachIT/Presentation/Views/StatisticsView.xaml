<!-- Statistics placeholder content. -->
<UserControl x:Class="ReachIT.Presentation.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel>
            <TextBlock Text="Statistics" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding ProjectStats.TotalFiles, StringFormat=Total files: {0}}" />
            <TextBlock Text="{Binding ProjectStats.TotalTasks, StringFormat=Total tasks: {0}}" />
            <TextBlock Text="{Binding ProjectStats.CompletedTasks, StringFormat=Completed tasks: {0}}" />
        </StackPanel>
    </Grid>
</UserControl>
