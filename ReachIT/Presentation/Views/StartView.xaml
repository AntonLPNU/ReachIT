<!-- Start menu content shown before opening workspace. -->
<UserControl x:Class="ReachIT.Presentation.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="ReachIT" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12" />

        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <Button Content="Open Project Folder" Command="{Binding OpenProjectCommand}" Margin="0,0,8,8" />
            <Button Content="Create New Project" Command="{Binding CreateProjectCommand}" Margin="0,0,8,8" />
            <Button Content="Settings" Command="{Binding OpenSettingsCommand}" Margin="0,0,8,8" />
            <Button Content="Exit" Command="{Binding ExitCommand}" Margin="0,0,8,8" />
        </WrapPanel>

        <GroupBox Grid.Row="2" Header="Recent Projects" Margin="0,0,0,8">
            <ListBox ItemsSource="{Binding RecentProjects}" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding ProjectName}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ProjectDirectoryPath}" FontSize="11" Opacity="0.8" />
                            </StackPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="Open"
                                    Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Margin="8,0,0,0" />
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Recent External Files">
            <ListBox ItemsSource="{Binding RecentExternalFiles}" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right"
                                    Content="Open"
                                    Command="{Binding DataContext.OpenRecentExternalFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Margin="8,0,0,0" />
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </Grid>
</UserControl>
