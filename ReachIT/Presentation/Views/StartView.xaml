<UserControl x:Class="ReachIT.Presentation.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <UserControl.Resources>
        <Style x:Key="StartActionButtonStyle" BasedOn="{StaticResource ReachItSecondaryButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="58" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="StartPrimaryActionButtonStyle" BasedOn="{StaticResource StartActionButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource ReachItPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SkyAquaBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="StartListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="StartListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource ReachItWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource ReachItHeroCardStyle}" Padding="24,22" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Start.Title}" Foreground="White" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="{DynamicResource Start.Subtitle}"
                               Foreground="#EAF7FF"
                               FontSize="14"
                               Margin="0,8,0,0"
                               MaxWidth="760" />
                </StackPanel>
                <Grid Grid.Column="1"
                      Width="92"
                      Height="92"
                      Margin="8,0,14,0"
                      Opacity="0.92">
                    <Ellipse Stroke="#72FFFFFF" StrokeThickness="2" Fill="#16FFFFFF" />
                    <Ellipse Width="68" Height="68" Stroke="#55FFFFFF" StrokeThickness="1" Fill="#10FFFFFF" />
                    <Path Data="M25,56 L43,72 L68,34"
                          Stroke="White"
                          StrokeThickness="7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Opacity="0.92" />
                    <Rectangle Width="8" Height="25" RadiusX="3" RadiusY="3" Fill="White" Opacity="0.72" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="29,0,0,25" />
                    <Rectangle Width="8" Height="41" RadiusX="3" RadiusY="3" Fill="White" Opacity="0.84" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="42,0,0,25" />
                    <Rectangle Width="8" Height="56" RadiusX="3" RadiusY="3" Fill="White" Opacity="0.96" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="55,0,0,25" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ReachItCardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Start.QuickActions}" Style="{StaticResource ReachItSectionTitleTextStyle}" />

                    <Button Command="{Binding CreateProjectCommand}" Style="{StaticResource StartPrimaryActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Kind="PlusCircle" Width="22" Height="22" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{DynamicResource Start.CreateProject}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button Command="{Binding OpenProjectCommand}" Style="{StaticResource StartActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="22" Height="22" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{DynamicResource Start.OpenProject}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button Command="{Binding OpenSettingsCommand}" Style="{StaticResource StartActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Kind="Cog" Width="22" Height="22" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{DynamicResource Start.Settings}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button Command="{Binding ExitCommand}"
                            Style="{StaticResource ReachItDangerButtonStyle}"
                            Height="48"
                            HorizontalContentAlignment="Stretch"
                            Padding="14,8"
                            Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Kind="ExitToApp" Width="20" Height="20" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{DynamicResource Start.Exit}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ReachItCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource Start.RecentProjects}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding RecentProjects}"
                             Style="{StaticResource StartListBoxStyle}"
                             ItemContainerStyle="{StaticResource StartListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#101B2E"
                                        BorderBrush="#253858"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProjectName}" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ProjectDirectoryPath}"
                                                       FontSize="11"
                                                       Style="{StaticResource ReachItMutedTextStyle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,4,12,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource ReachItIconButtonStyle}"
                                                    Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{DynamicResource Start.Open}">
                                                <iconPacks:PackIconMaterial Kind="FolderOpen" Width="17" Height="17" />
                                            </Button>
                                            <Button Style="{StaticResource ReachItIconButtonStyle}"
                                                    Command="{Binding DataContext.OpenRecentProjectFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{DynamicResource Start.Folder}">
                                                <iconPacks:PackIconMaterial Kind="Folder" Width="17" Height="17" />
                                            </Button>
                                            <Button Style="{StaticResource ReachItDangerIconButtonStyle}"
                                                    Command="{Binding DataContext.RemoveRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{DynamicResource Start.Remove}">
                                                <iconPacks:PackIconMaterial Kind="Delete" Width="17" Height="17" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <StackPanel Grid.Column="4">
                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Start.Account}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <Button Command="{Binding OpenAccountCommand}"
                                Style="{StaticResource ReachItSecondaryButtonStyle}"
                                HorizontalContentAlignment="Stretch"
                                Padding="12,8"
                                Margin="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Kind="AccountCircle" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding AccountStatusText}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Start.WhatsNew}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <TextBlock Text="{DynamicResource Start.News1}" />
                        <TextBlock Text="{DynamicResource Start.News2}" Style="{StaticResource ReachItMutedTextStyle}" Margin="0,8,0,0" />
                        <TextBlock Text="{DynamicResource Start.News3}" Style="{StaticResource ReachItMutedTextStyle}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Start.RecentExternalFiles}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <ListBox ItemsSource="{Binding RecentExternalFiles}"
                                 Style="{StaticResource StartListBoxStyle}"
                                 ItemContainerStyle="{StaticResource StartListBoxItemStyle}"
                                 MaxHeight="160">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#101B2E"
                                            BorderBrush="#253858"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <DockPanel LastChildFill="True">
                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource ReachItIconButtonStyle}"
                                                    Command="{Binding DataContext.OpenRecentExternalFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{DynamicResource Start.Open}">
                                                <iconPacks:PackIconMaterial Kind="OpenInNew" Width="15" Height="15" />
                                            </Button>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,8,0" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
