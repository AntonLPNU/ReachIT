<UserControl x:Class="ReachIT.Presentation.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid Margin="18" Background="{StaticResource ReachItWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource ReachItHeroCardStyle}" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Source="Resources/AppIcon.png" Width="58" Height="58" Stretch="Uniform" />
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource Start.Title}" Foreground="White" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="{DynamicResource Start.Subtitle}" Foreground="#EAF7FF" Margin="0,6,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Button Command="{Binding OpenProjectCommand}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="16" Height="16" Margin="0,0,8,0" />
                    <TextBlock Text="{DynamicResource Start.OpenProject}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding CreateProjectCommand}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="PlusCircle" Width="16" Height="16" Margin="0,0,8,0" />
                    <TextBlock Text="{DynamicResource Start.CreateProject}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding OpenSettingsCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Cog" Width="16" Height="16" Margin="0,0,8,0" />
                    <TextBlock Text="{DynamicResource Start.Settings}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding ExitCommand}" Style="{StaticResource ReachItDangerButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ExitToApp" Width="16" Height="16" Margin="0,0,8,0" />
                    <TextBlock Text="{DynamicResource Start.Exit}" />
                </StackPanel>
            </Button>
        </WrapPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ReachItCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource Start.RecentProjects}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                    <ListBox Grid.Row="1" ItemsSource="{Binding RecentProjects}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                        <Button Style="{StaticResource ReachItCompactButtonStyle}"
                                                Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{DynamicResource Start.Open}">
                                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" />
                                        </Button>
                                        <Button Style="{StaticResource ReachItSecondaryButtonStyle}"
                                                Command="{Binding DataContext.OpenRecentProjectFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="42"
                                                ToolTip="{DynamicResource Start.Folder}">
                                            <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14" />
                                        </Button>
                                        <Button Style="{StaticResource ReachItDangerButtonStyle}"
                                                Command="{Binding DataContext.RemoveRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="42"
                                                ToolTip="{DynamicResource Start.Remove}">
                                            <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" />
                                        </Button>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ProjectDirectoryPath}" FontSize="11" Style="{StaticResource ReachItMutedTextStyle}" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Start.WhatsNew}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <TextBlock Text="{DynamicResource Start.News1}" />
                        <TextBlock Text="{DynamicResource Start.News2}" Style="{StaticResource ReachItMutedTextStyle}" Margin="0,8,0,0" />
                        <TextBlock Text="{DynamicResource Start.News3}" Style="{StaticResource ReachItMutedTextStyle}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Start.RecentExternalFiles}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <ListBox ItemsSource="{Binding RecentExternalFiles}" BorderThickness="0" MaxHeight="160">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource ReachItCompactButtonStyle}"
                                                Command="{Binding DataContext.OpenRecentExternalFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="8,0,0,0"
                                                ToolTip="{DynamicResource Start.Open}">
                                            <iconPacks:PackIconMaterial Kind="OpenInNew" Width="14" Height="14" />
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
