<!-- Recent external files panel displayed below explorer tree. -->
<UserControl x:Class="ReachIT.Presentation.Views.RecentExternalFilesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Recent External Files" Style="{StaticResource ReachItSectionTitleTextStyle}" Margin="0,0,0,8" />

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem}"
                 DisplayMemberPath="DisplayName" />

        <WrapPanel Grid.Row="2" Margin="0,6,0,0">
            <Button Content="+ Attach" Command="{Binding AttachToProjectCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" />
            <Button Content="⧉ Copy" Command="{Binding CopyIntoProjectCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" />
            <Button Content="🔗 Link" Command="{Binding SaveAsLinkCommand}" Style="{StaticResource ReachItSecondaryButtonStyle}" />
            <Button Content="× Remove" Command="{Binding RemoveFromRecentCommand}" Style="{StaticResource ReachItDangerButtonStyle}" />
        </WrapPanel>
    </Grid>
</UserControl>
