<!-- Settings placeholder content. -->
<UserControl x:Class="ReachIT.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                <TextBlock Text="{DynamicResource Settings.Title}" Style="{StaticResource ReachItPageTitleTextStyle}" Margin="0,0,0,16" />

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Account" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <TextBlock Text="Local profile" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding AccountDisplayName}"
                                 Margin="0,4,0,10"
                                 ToolTip="Name shown for the local ReachIT account." />

                        <TextBlock Text="Email" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding AccountEmail}"
                                 Margin="0,4,0,10"
                                 ToolTip="Future billing or sign-in email. Stored locally for now." />

                        <TextBlock Text="Subscription plan" Style="{StaticResource ReachItLabelTextStyle}" />
                        <ComboBox ItemsSource="{Binding AvailableSubscriptionPlans}"
                                  SelectedItem="{Binding SubscriptionPlan}"
                                  Width="180"
                                  HorizontalAlignment="Left"
                                  Margin="0,4,0,10"
                                  ToolTip="Local subscription simulation for future feature gating." />

                        <TextBlock Text="{Binding SubscriptionStatusText}"
                                   Style="{StaticResource ReachItMutedTextStyle}"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="Feature access" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding AccountFeatureSummary, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="120"
                                 Margin="0,4,0,0"
                                 Background="#18243A"
                                 ToolTip="Features are evaluated through IEntitlementService, separate from internal app services." />

                        <Border Background="#101B2E"
                                BorderBrush="#253858"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,14,0,0"
                                Visibility="{Binding IsDeveloperPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Developer test account" Style="{StaticResource ReachItLabelTextStyle}" />
                                <Grid Margin="0,8,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Login" Style="{StaticResource ReachItMutedTextStyle}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding DeveloperLogin, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="#18243A" />
                                    <TextBlock Grid.Row="1"
                                               Text="Password"
                                               Style="{StaticResource ReachItMutedTextStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding DeveloperPassword, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="#18243A"
                                             Margin="0,8,0,0" />
                                </Grid>

                                <Button Command="{Binding GenerateDeveloperProjectCommand}"
                                        Width="250"
                                        HorizontalAlignment="Left"
                                        ToolTip="Generate a large local demo project with varied files for testing ReachIT features.">
                                    <TextBlock Text="Generate demo test project" />
                                </Button>
                                <TextBlock Text="{Binding DeveloperToolStatus}"
                                           Style="{StaticResource ReachItMutedTextStyle}"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.General}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <CheckBox Content="{DynamicResource Settings.EnableNotifications}" IsChecked="{Binding EnableNotifications}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.ShowRelatedTasks}" IsChecked="{Binding ShowRelatedTasksInTree}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.HideSidePanel}" IsChecked="{Binding HideSidePanelAfterExternalFileOpen}" Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Settings.Language}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding Language}"
                                  Width="150"
                                  HorizontalAlignment="Left"
                                  Margin="0,4,0,0"
                                  ToolTip="{DynamicResource Settings.LanguageTip}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.WorkspaceFocus}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <TextBlock Text="{DynamicResource Settings.SidePanelHotkey}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding SidePanelHotkey}"
                                 Width="200"
                                 HorizontalAlignment="Left"
                                 Margin="0,4,0,12"
                                 ToolTip="Keyboard shortcut that opens or hides Project Explorer." />

                        <Border Background="#101B2E" BorderBrush="#253858" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Focus mode uses one strict whitelist." Style="{StaticResource ReachItLabelTextStyle}" />
                                <TextBlock Text="Manage allowed apps from the Focus Mode screen. Games and unknown apps are blocked only while focus is active."
                                           Style="{StaticResource ReachItMutedTextStyle}"
                                           Margin="0,4,0,10" />
                                <Button Command="{Binding DataContext.OpenFocusCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Width="190"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource ReachItSecondaryButtonStyle}"
                                        ToolTip="Open the app whitelist catalog.">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Open app whitelist" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Global Activity Defaults" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <CheckBox Content="{DynamicResource Settings.EnableActivityTracking}" IsChecked="{Binding EnableActivityTracking}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.TrackActiveWindow}" IsChecked="{Binding TrackActiveWindow}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.TrackFileChanges}" IsChecked="{Binding TrackFileChanges}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.TrackGitChanges}" IsChecked="{Binding TrackGitChanges}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.TrackTextStatistics}" IsChecked="{Binding TrackTextStatistics}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.IgnorePrivateApps}" IsChecked="{Binding IgnorePrivateApps}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.PauseActivityTracking}" IsChecked="{Binding PauseActivityTracking}" Margin="0,0,0,12" />

                        <Border Background="#101B2E" BorderBrush="#253858" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,4,0,0">
                            <TextBlock Text="Ignored files and folders are configured per project from the Current Project section or the project tree context menu."
                                       Style="{StaticResource ReachItMutedTextStyle}" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}"
                        Margin="0,0,0,16"
                        Visibility="{Binding HasCurrentProject, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Current Project" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <TextBlock Text="{Binding CurrentProjectName}" Style="{StaticResource ReachItLabelTextStyle}" Margin="0,0,0,8" />
                        <CheckBox Content="Use separate activity settings for this project"
                                  IsChecked="{Binding UseProjectActivitySettings}"
                                  Margin="0,0,0,12"
                                  ToolTip="Override global activity tracking for the currently opened project." />

                        <TextBlock Text="Project tracking profile" Style="{StaticResource ReachItLabelTextStyle}" />
                        <CheckBox Content="Enable activity tracking" IsChecked="{Binding ProjectEnableActivityTracking}" Margin="0,6,0,8" />
                        <CheckBox Content="Track active window" IsChecked="{Binding ProjectTrackActiveWindow}" Margin="0,0,0,8" />
                        <CheckBox Content="Track file changes" IsChecked="{Binding ProjectTrackFileChanges}" Margin="0,0,0,8" />
                        <CheckBox Content="Track git changes" IsChecked="{Binding ProjectTrackGitChanges}" Margin="0,0,0,8" />
                        <CheckBox Content="Track text statistics" IsChecked="{Binding ProjectTrackTextStatistics}" Margin="0,0,0,8" />
                        <CheckBox Content="Pause tracking for this project" IsChecked="{Binding ProjectPauseActivityTracking}" Margin="0,0,0,12" />

                        <TextBlock Text="Project ignored files and folders" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding ProjectIgnoredFolders}"
                                 Margin="0,4,0,0"
                                 ToolTip="Project-specific ignored folders, file names, or relative paths." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.DataBackup}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <TextBlock Text="{DynamicResource Settings.DatabasePath}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding AppDataLocation, Mode=OneWay}" IsReadOnly="True" Margin="0,4,0,12" Background="#18243A" ToolTip="Current local database file." />

                        <TextBlock Text="{DynamicResource Settings.BackupLocationPath}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding BackupLocationPath}" Margin="0,4,0,0" ToolTip="Directory where backups will be saved automatically." />
                    </StackPanel>
                </Border>

                <Button Content="{DynamicResource Settings.Save}" Command="{Binding SaveCommand}" Width="190" HorizontalAlignment="Left" Height="34" ToolTip="{DynamicResource Settings.SaveTip}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
