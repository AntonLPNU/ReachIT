<!-- Settings placeholder content. -->
<UserControl x:Class="ReachIT.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:ReachIT.Domain.Enums">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                <TextBlock Text="{DynamicResource Settings.Title}" Style="{StaticResource ReachItPageTitleTextStyle}" Margin="0,0,0,16" />

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.General}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <CheckBox Content="{DynamicResource Settings.EnableNotifications}" IsChecked="{Binding EnableNotifications}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.ShowRelatedTasks}" IsChecked="{Binding ShowRelatedTasksInTree}" Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource Settings.HideSidePanel}" IsChecked="{Binding HideSidePanelAfterExternalFileOpen}" Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Settings.Theme}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding Theme}"
                                  Width="150"
                                  HorizontalAlignment="Left"
                                  Margin="0,4,0,12"
                                  ToolTip="Choose how ReachIT should color the interface." />

                        <TextBlock Text="{DynamicResource Settings.Language}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding Language}"
                                  Width="150"
                                  HorizontalAlignment="Left"
                                  Margin="0,4,0,0"
                                  ToolTip="{DynamicResource Settings.LanguageTip}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.WorkspaceFocus}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <TextBlock Text="{DynamicResource Settings.SidePanelHotkey}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding SidePanelHotkey}"
                                 Width="200"
                                 HorizontalAlignment="Left"
                                 Margin="0,4,0,12"
                                 ToolTip="Keyboard shortcut that opens or hides Project Explorer." />

                        <TextBlock Text="{DynamicResource Settings.DefaultFocusMode}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <ComboBox SelectedItem="{Binding DefaultFocusMode}" Width="150" HorizontalAlignment="Left" Margin="0,4,0,0" ToolTip="Default focus mode used when starting a focus session.">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type enums:FocusModeType}">
                                    <enums:FocusModeType>Light</enums:FocusModeType>
                                    <enums:FocusModeType>Strict</enums:FocusModeType>
                                    <enums:FocusModeType>Aggressive</enums:FocusModeType>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ReachItCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.DataBackup}" Style="{StaticResource ReachItSectionTitleTextStyle}" />
                        <TextBlock Text="{DynamicResource Settings.DatabasePath}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding AppDataLocation, Mode=OneWay}" IsReadOnly="True" Margin="0,4,0,12" Background="#18243A" ToolTip="Current local database file." />

                        <TextBlock Text="{DynamicResource Settings.BackupLocationPath}" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox Text="{Binding BackupLocationPath}" Margin="0,4,0,0" ToolTip="Directory where backups will be saved automatically." />
                    </StackPanel>
                </Border>

                <Button Content="{DynamicResource Settings.Save}" Command="{Binding SaveCommand}" Width="190" HorizontalAlignment="Left" Height="34" ToolTip="{DynamicResource Settings.SaveTip}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
