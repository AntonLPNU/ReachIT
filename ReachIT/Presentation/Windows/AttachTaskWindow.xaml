<Window x:Class="ReachIT.Presentation.Windows.AttachTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Attach task"
        Width="720"
        Height="560"
        MinWidth="640"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Attach task to file"
                       Style="{StaticResource ReachItPageTitleTextStyle}"
                       FontSize="26" />
            <TextBlock x:Name="FilePathText"
                       Style="{StaticResource ReachItMutedTextStyle}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" MinWidth="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.95*" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource ReachItPanelStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <iconPacks:PackIconMaterial Kind="PlusCircle"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource SkyAquaBrush}"
                                                    Margin="0,0,8,0" />
                        <TextBlock Text="Create new"
                                   Style="{StaticResource ReachItSectionTitleTextStyle}"
                                   Margin="0" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Title" Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox x:Name="TitleBox"
                                 Grid.Row="1"
                                 Margin="0,4,0,10"
                                 MaxLength="160" />

                        <TextBlock Grid.Row="2" Text="Due date" Style="{StaticResource ReachItLabelTextStyle}" />
                        <DatePicker x:Name="DueDatePicker"
                                    Grid.Row="3"
                                    Margin="0,4,0,0" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Goal / done when"
                                   Style="{StaticResource ReachItLabelTextStyle}" />
                        <TextBox x:Name="DescriptionBox"
                                 Grid.Row="1"
                                 Margin="0,4,0,0"
                                 MinHeight="130"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top" />
                    </Grid>

                    <Button x:Name="CreateButton"
                            Grid.Row="3"
                            Margin="0,14,0,0"
                            Click="OnCreateClick">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Plus"
                                                        Width="16"
                                                        Height="16"
                                                        Margin="0,0,8,0" />
                            <TextBlock Text="Create and attach" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ReachItPanelStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <iconPacks:PackIconMaterial Kind="LinkVariant"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource SkyAquaBrush}"
                                                    Margin="0,0,8,0" />
                        <TextBlock Text="Attach existing"
                                   Style="{StaticResource ReachItSectionTitleTextStyle}"
                                   Margin="0" />
                    </StackPanel>

                    <TextBox x:Name="TaskSearchBox"
                             Grid.Row="1"
                             Margin="0,0,0,10"
                             TextChanged="OnTaskSearchChanged" />

                    <ListBox x:Name="ExistingTasksList"
                             Grid.Row="2"
                             SelectionChanged="OnExistingTaskSelectionChanged"
                             MouseDoubleClick="OnExistingTaskDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource ReachItMutedTextStyle}"
                                               FontSize="12"
                                               MaxHeight="38"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button x:Name="AttachExistingButton"
                            Grid.Row="3"
                            Style="{StaticResource ReachItSecondaryButtonStyle}"
                            Margin="0,14,0,0"
                            IsEnabled="False"
                            Click="OnAttachExistingClick">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Link"
                                                        Width="16"
                                                        Height="16"
                                                        Margin="0,0,8,0" />
                            <TextBlock Text="Attach selected" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <TextBlock x:Name="ValidationText"
                       Foreground="{StaticResource NeonPinkBrush}"
                       VerticalAlignment="Center" />
            <Button Content="Cancel"
                    Style="{StaticResource ReachItSecondaryButtonStyle}"
                    HorizontalAlignment="Right"
                    MinWidth="110"
                    Click="OnCancelClick" />
        </Grid>
    </Grid>
</Window>
